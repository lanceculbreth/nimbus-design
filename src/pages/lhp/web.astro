---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="LHP Web" active="web" sections={[
  { label: 'Site Structure', id: 'sitemap' },
  { label: 'Hero', id: 'hero' },
  { label: 'CTAs', id: 'ctas' },
  { label: 'Trust Signals', id: 'trust' },
]}>
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <div class="mb-16">
      <p class="font-inter text-teal text-sm font-semibold uppercase tracking-[0.12em] mb-3">Nimbus Design &middot; LHP</p>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Web
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        Web design patterns used on lakehillsrx.com.
      </p>
      <a href="https://www.lakehillsrx.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-6 px-4 py-2 rounded-full bg-dark text-cream text-xs font-inter font-medium hover:bg-dark/80 transition-colors">
        Visit lakehillsrx.com &rarr;
      </a>
    </div>

    <section id="sitemap" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Site Structure</h2>
      <div class="flex flex-wrap gap-2">
        {['Products', 'Supplements', 'Services', 'Long-Term Care', 'About Us', 'Blog', 'Licenses'].map(item => (
          <span class="bg-dark/5 text-dark font-inter text-sm font-medium px-4 py-2 rounded-full border border-dark/8">{item}</span>
        ))}
      </div>
    </section>

    <section id="hero" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Hero Pattern</h2>
      <div class="bg-dark rounded-3xl p-10 mb-6 text-center">
        <h3 class="font-fraunces text-cream text-[clamp(24px,3.5vw,40px)] leading-[1.1] tracking-[-0.02em] mb-3">The Pharmacy Powering Personalized Medicine</h3>
        <p class="font-inter text-cream/60 text-sm mb-6">powered by Health OS&trade;</p>
        <div class="flex justify-center gap-3">
          <span class="bg-cream text-dark font-inter text-sm font-medium px-5 py-2 rounded-full">For Providers</span>
          <span class="bg-cream/10 text-cream font-inter text-sm font-medium px-5 py-2 rounded-full border border-cream/20">For Patients</span>
        </div>
      </div>
      <div class="bg-warm-gray rounded-3xl p-8">
        <h3 class="font-inter text-sm font-semibold mb-4">Hero Rules</h3>
        <ul class="space-y-2 font-inter text-sm text-dark/60">
          <li>Full-width dark hero with centered headline + subheadline</li>
          <li>Dual CTAs: <span class="text-dark font-medium">For Providers</span> (primary) and <span class="text-dark font-medium">For Patients</span> (secondary)</li>
          <li>Tagline <span class="text-dark font-medium">"powered by Health OS™"</span> beneath headline</li>
          <li>Trust badges (NABP, LegitScript, PCAB) below fold</li>
        </ul>
      </div>
    </section>

    <section id="ctas" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">CTAs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-warm-gray rounded-2xl p-6">
          <p class="font-inter text-sm font-semibold text-teal mb-1">For Providers</p>
          <p class="font-inter text-sm text-dark/60 leading-[1.6]">Compounding, APIs, and white-label fulfillment for clinical and digital-health partners.</p>
        </div>
        <div class="bg-warm-gray rounded-2xl p-6">
          <p class="font-inter text-sm font-semibold text-teal mb-1">For Patients</p>
          <p class="font-inter text-sm text-dark/60 leading-[1.6]">Retail prescriptions, supplements, and long-term-care wellness locally in Bee Caves, TX.</p>
        </div>
      </div>
    </section>

    <section id="trust" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Trust Signals</h2>
      <div class="bg-dark rounded-3xl p-8">
        <div class="flex flex-wrap items-center justify-center gap-6 text-cream/70 font-inter text-sm">
          <span>NABP-Accredited</span>
          <span class="text-cream/20">|</span>
          <span>LegitScript Verified</span>
          <span class="text-cream/20">|</span>
          <span>PCAB Compounding</span>
          <span class="text-cream/20">|</span>
          <span>Independent 503A</span>
        </div>
      </div>
    </section>

  </div>
</Layout>
