---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="LHP Positioning" active="marketing" sections={[
  { label: 'Promise', id: 'promise' },
  { label: 'What We Do', id: 'services' },
  { label: 'Who We Serve', id: 'audience' },
  { label: 'Differentiators', id: 'different' },
]}>
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <div class="mb-16">
      <p class="font-inter text-teal text-sm font-semibold uppercase tracking-[0.12em] mb-3">Nimbus Design &middot; LHP</p>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Positioning
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        Lake Hills Pharmacy's brand promise, audience, and differentiators.
      </p>
    </div>

    <section id="promise" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Brand Promise</h2>
      <div class="bg-dark rounded-3xl p-10 text-center">
        <p class="font-inter text-cream/40 text-xs font-semibold uppercase tracking-[0.15em] mb-4">The Promise</p>
        <h3 class="font-fraunces text-cream text-[clamp(28px,4vw,44px)] leading-[1.1] tracking-[-0.02em] mb-3">The Pharmacy Powering<br/>Personalized Medicine</h3>
        <p class="font-inter text-cream/60 text-sm">powered by Health OS&trade;</p>
      </div>
    </section>

    <section id="services" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">What We Do</h2>
      <div class="bg-warm-gray rounded-3xl p-8">
        <p class="font-inter text-dark/70 text-base leading-[1.7]">
          An independent, NABP-accredited 503A compounding pharmacy delivering custom compounding, high-volume fulfillment, APIs, and end-to-end digital pharmacy solutions. The fulfillment engine behind Nimbus Healthcare prescriptions.
        </p>
      </div>
    </section>

    <section id="audience" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Who We Serve</h2>
      <div class="space-y-4">
        <div class="bg-dark rounded-2xl p-6 flex gap-5">
          <div class="w-8 h-8 rounded-full bg-teal/20 flex items-center justify-center flex-shrink-0 mt-0.5">
            <span class="font-inter text-teal text-sm font-semibold">1</span>
          </div>
          <div>
            <p class="font-inter text-cream text-sm font-semibold mb-1">Providers <span class="text-cream/40 font-normal">(primary)</span></p>
            <p class="font-inter text-cream/60 text-sm leading-[1.6]">Clinicians and digital health partners needing scalable compounding, APIs, and fulfillment infrastructure.</p>
          </div>
        </div>
        <div class="bg-dark rounded-2xl p-6 flex gap-5">
          <div class="w-8 h-8 rounded-full bg-teal/20 flex items-center justify-center flex-shrink-0 mt-0.5">
            <span class="font-inter text-teal text-sm font-semibold">2</span>
          </div>
          <div>
            <p class="font-inter text-cream text-sm font-semibold mb-1">Patients <span class="text-cream/40 font-normal">(retail)</span></p>
            <p class="font-inter text-cream/60 text-sm leading-[1.6]">Local retail, supplements, and long-term-care wellness for the Bee Caves community.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="different" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">What Makes Us Different</h2>
      <div class="space-y-3">
        {[
          { label: 'Trusted, Accredited Compounding Excellence', body: 'NABP, LegitScript, and PCAB certified — precision and safety built in.' },
          { label: 'API-first, Tech-enabled', body: 'Health OS™ powers every intake, order, and shipment with developer-grade APIs.' },
          { label: 'Custom Compounding at Scale', body: 'Both sterile and non-sterile formulations, delivered with speed and precision.' },
          { label: 'White-Label Partnerships', body: 'Custom branding and packaging for clinical partners and digital-health brands.' },
        ].map(item => (
          <div class="bg-warm-gray rounded-2xl p-6">
            <p class="font-inter text-sm font-semibold text-dark mb-1">{item.label}</p>
            <p class="font-inter text-sm text-dark/60 leading-[1.6]">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>
