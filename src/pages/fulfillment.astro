<script is:inline>
  function switchTimeline(active) {
    ['1mo','3mo','6mo'].forEach(id => {
      const panel = document.getElementById('panel-tl-' + id);
      const btn = document.querySelector(`[data-tl="${id}"]`);
      if (id === active) {
        panel.classList.remove('hidden');
        btn.className = 'tl-tab px-4 py-2 rounded-full text-sm font-medium transition-all bg-dark text-cream';
      } else {
        panel.classList.add('hidden');
        btn.className = 'tl-tab px-4 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark';
      }
    });
  }
</script>
