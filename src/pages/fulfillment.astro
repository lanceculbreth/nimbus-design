---
import Layout from '../layouts/Layout.astro';

const sections = [
  { label: 'How It Works', id: 'overview' },
  { label: 'Subscription Statuses', id: 'statuses' },
  { label: 'Plan Timelines', id: 'timelines' },
  { label: 'Billing', id: 'billing' },
  { label: 'Medication & Pricing', id: 'pricing' },
  { label: 'Refill Cycle', id: 'refill' },
  { label: 'Fulfillment', id: 'fulfillment' },
  { label: 'Inactive & Win-back', id: 'inactive' },
  { label: 'Plan Changes', id: 'plan-changes' },
  { label: 'Cancellation', id: 'cancellation' },
  { label: 'Edge Cases', id: 'edge-cases' },
  { label: 'Action Items', id: 'action-items' },
];

const monthly = 'inline-flex items-center px-2 py-0.5 rounded-full bg-teal/10 text-teal text-xs font-semibold';
const commitment = 'inline-flex items-center px-2 py-0.5 rounded-full bg-terracotta/10 text-terracotta text-xs font-semibold';
const allPlans = 'inline-flex items-center px-2 py-0.5 rounded-full bg-dark/8 text-dark/60 text-xs font-semibold';
const decided = 'inline-flex items-center px-2 py-0.5 rounded-full bg-teal/10 text-teal text-xs font-medium gap-1';
const pending = 'inline-flex items-center px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 text-xs font-medium gap-1';
---

<Layout title="Billing, Refill & Fulfillment" active="fulfillment" sections={sections}>
  <div class="max-w-[860px] mx-auto px-10 py-16">

    <!-- Header -->
    <div class="mb-14">
      <p class="font-inter text-teal text-xs font-semibold tracking-widest uppercase mb-3">WeightWise</p>
      <h1 class="font-fraunces text-4xl font-semibold text-dark leading-tight mb-4">Billing, Refill & Fulfillment</h1>
      <p class="font-inter text-dark/50 text-lg leading-relaxed max-w-[580px]">
        How the money moves, how medication ships, and how the refill cycle works — distilled for quick reference.
      </p>
      <div class="flex items-center gap-3 mt-6">
        <span class={monthly}>Monthly</span>
        <span class={commitment}>3 / 6-month</span>
        <span class={allPlans}>All plans</span>
        <span class="font-inter text-dark/30 text-xs">— plan type indicators used throughout</span>
      </div>
    </div>

    <!-- ─── HOW IT WORKS (overview) ─── -->
    <section id="overview" class="mb-16 scroll-mt-8">
      <h2 class="font-fraunces text-2xl font-semibold text-dark mb-6">How It Works at a Glance</h2>

      <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-teal/8 border border-teal/15 rounded-2xl p-5">
          <p class={`${monthly} mb-3`}>Monthly</p>
          <p class="font-inter text-dark font-semibold text-sm mb-2">Pay as you engage</p>
          <p class="font-inter text-dark/60 text-sm leading-relaxed">Card held on file at signup — <strong>no charge until your provider writes a prescription</strong>. Every 28 days, complete a check-in → provider reviews → prescription issued → <em>then</em> you're charged.</p>
        </div>
        <div class="bg-terracotta/8 border border-terracotta/15 rounded-2xl p-5">
          <p class={`${commitment} mb-3`}>3 / 6-Month</p>
          <p class="font-inter text-dark font-semibold text-sm mb-2">Pay upfront in full</p>
          <p class="font-inter text-dark/60 text-sm leading-relaxed">Full 3 or 6-month cost charged immediately at signup. Monthly check-ins still required to release each shipment. <strong>Klarna/Afterpay</strong> integration planned to make this digestible at checkout.</p>
        </div>
      </div>

      <!-- Quick facts -->
      <div class="grid grid-cols-4 gap-3">
        {[
          { label: 'Medication cycle', value: '28 days', sub: '1 shot/week' },
          { label: 'Monthly inactivity cutoff', value: 'Day 44', sub: '5:00 PM CT' },
          { label: 'Commitment inactivity', value: 'End of\nbilling period', sub: '11:59 PM CT' },
          { label: '3/6-mo intake deadline', value: '7 days', sub: 'then auto-refund' },
        ].map(f => (
          <div class="bg-white border border-dark/8 rounded-xl p-4 text-center">
            <p class="font-inter text-dark/40 text-xs mb-1">{f.label}</p>
            <p class="font-fraunces text-xl font-semibold text-dark whitespace-pre-line leading-tight">{f.value}</p>
            <p class="font-inter text-dark/30 text-xs mt-1">{f.sub}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── SUBSCRIPTION STATUSES ─── -->
    <section id="statuses" class="mb-16 scroll-mt-8">
      <h2 class="font-fraunces text-2xl font-semibold text-dark mb-2">Subscription Statuses</h2>
      <p class="font-inter text-dark/40 text-sm mb-6">Every patient account is always in one of these states. Status drives portal UI, billing behavior, and which notifications fire.</p>

      <div class="bg-white border border-dark/8 rounded-2xl overflow-hidden">
        <div class="grid grid-cols-12 bg-warm-gray/50 border-b border-dark/8 px-5 py-3">
          <p class="font-inter text-dark/50 text-xs font-semibold col-span-4">Status</p>
          <p class="font-inter text-dark/50 text-xs font-semibold col-span-8">What it means</p>
        </div>
        {[
          { status: 'Active', color: 'bg-teal', desc: 'Payment confirmed, subscription running normally. Patient is in good standing.' },
          { status: 'Active – Pending Fulfillment', color: 'bg-teal/60', desc: 'MDI (provider) has approved and sent prescription to pharmacy. Awaiting shipment.' },
          { status: 'Active – In Treatment', color: 'bg-teal/40', desc: 'Medication received. Patient is actively on treatment. Next refill window approaching.' },
          { status: 'Active – At Risk', color: 'bg-amber-400', desc: '1-month only. Intake not completed, approaching the Day 44 deadline. Nudge sequence in progress.' },
          { status: 'Active – Past Due', color: 'bg-terracotta', desc: 'Payment failed on a 3/6-month renewal. Stripe Smart Retry dunning sequence in progress.' },
          { status: 'Active – Renewed', color: 'bg-teal', desc: '3/6-month auto-renewal payment succeeded. New term has started.' },
          { status: 'Inactive', color: 'bg-dark/40', desc: 'Intake deadline missed (Day 44), payment unresolved at end of billing period, or migration not completed at T+30. Resume path always available — no full re-enrollment required.' },
        ].map(s => (
          <div class="grid grid-cols-12 px-5 py-3.5 border-b border-dark/5 last:border-0 items-start">
            <div class="col-span-4 flex items-center gap-2.5">
              <div class={`w-2 h-2 rounded-full flex-shrink-0 ${s.color}`}></div>
              <p class="font-inter text-dark text-sm font-semibold">{s.status}</p>
            </div>
            <p class="font-inter text-dark/55 text-sm leading-relaxed col-span-8">{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="bg-dark/4 border border-dark/8 rounded-xl p-4 mt-4">
        <p class="font-inter text-dark/60 text-xs leading-relaxed"><strong class="text-dark/80">Portal behavior when Inactive:</strong> Full portal UI remains visible but greyed out. An overlay appears with context-specific messaging and a Resume CTA. Resuming requires payment + completing intake questionnaire → status returns to Active – Pending Fulfillment. Existing patient record and history retained.</p>
      </div>
    </section>

    <!-- ─── PLAN TIMELINES ─── -->
    <section id="timelines" class="mb-16 scroll-mt-8">
      <h2 class="font-fraunces text-2xl font-semibold text-dark mb-2">Plan Timelines & State Machines</h2>
      <p class="font-inter text-dark/40 text-sm mb-6">The day-by-day progression of each plan type — from purchase to renewal or inactivity.</p>

      <!-- Plan tabs -->
      <div class="flex gap-2 mb-5" id="timeline-tabs">
        {[
          { id: '1mo', label: '1-Month' },
          { id: '3mo', label: '3-Month' },
          { id: '6mo', label: '6-Month' },
        ].map((t, i) => (
          <button
            data-tl={t.id}
            onclick={`switchTimeline('${t.id}')`}
            class={`tl-tab px-4 py-2 rounded-full text-sm font-medium transition-all ${i === 0 ? 'bg-dark text-cream' : 'bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark'}`}
          >
            {t.label}
          </button>
        ))}
      </div>

      <!-- 1-Month Timeline -->
      <div id="panel-tl-1mo">
        <div class="bg-white border border-dark/8 rounded-2xl overflow-hidden mb-4">
          <div class="grid grid-cols-12 bg-warm-gray/50 border-b border-dark/8 px-5 py-3">
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-2">Day</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-4">Event</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-3">Status</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-3">Trigger</p>
          </div>
          {[
            { day: 'Day 1', event: 'Purchase', status: 'Active', trigger: 'Payment success', hi: false },
            { day: 'Day 2', event: 'MDI approved, sent to pharmacy', status: 'Active – Pending Fulfillment', trigger: 'Clinical approval', hi: false },
            { day: 'Day 7', event: 'Medication received', status: 'Active – In Treatment', trigger: 'Shipment delivered', hi: false },
            { day: 'Day 20', event: 'Renewal nudge email #1', status: 'Active', trigger: 'Scheduled', hi: false },
            { day: 'Day 27', event: 'Urgency nudge email #2', status: 'Active', trigger: 'Scheduled', hi: false },
            { day: 'Day 28', event: '"Do it today" email — 5 business day guarantee', status: 'Active', trigger: 'Scheduled', hi: false },
            { day: 'Day 31', event: 'Missed intake warning', status: 'Active – At Risk', trigger: 'Intake not completed', hi: true },
            { day: 'Day 37', event: 'Cancellation warning', status: 'Active – At Risk', trigger: 'Intake still incomplete', hi: true },
            { day: 'Day 43', event: 'Final nudge + $25 COMMIT offer (expires Day 44)', status: 'Active – At Risk', trigger: 'Scheduled', hi: true },
            { day: 'Day 44 @ 5pm CT', event: 'Hard deadline — intake not completed', status: 'Inactive', trigger: 'System trigger', hi: true },
          ].map(r => (
            <div class={`grid grid-cols-12 px-5 py-3 border-b border-dark/5 last:border-0 ${r.hi ? 'bg-red-50/40' : ''}`}>
              <p class="font-inter text-dark/50 text-xs font-mono col-span-2 self-center">{r.day}</p>
              <p class="font-inter text-dark/70 text-xs col-span-4 self-center">{r.event}</p>
              <p class={`font-inter text-xs font-semibold col-span-3 self-center ${r.status === 'Inactive' ? 'text-dark/40' : r.status.includes('At Risk') ? 'text-amber-600' : 'text-teal'}`}>{r.status}</p>
              <p class="font-inter text-dark/30 text-xs col-span-3 self-center">{r.trigger}</p>
            </div>
          ))}
        </div>
        <div class="bg-teal/5 border border-teal/15 rounded-xl p-4">
          <p class="font-inter text-dark/60 text-xs font-semibold mb-2">1-Month Email Sequence</p>
          <div class="space-y-1.5">
            {[
              { day: 'Day 20', subject: '"Hope you\'re well — don\'t forget to complete your renewal by Day 28 to receive your next dose"' },
              { day: 'Day 27', subject: '"Intake due by 5pm tomorrow to receive next month\'s dose"' },
              { day: 'Day 28', subject: '"Do it today — next prescription will arrive within 5 business days, guaranteed"' },
              { day: 'Day 31', subject: '"You missed your refill intake. Complete it today to avoid interruption"' },
              { day: 'Day 37', subject: '"Complete your intake by Day 44 or your membership will become inactive"' },
              { day: 'Day 43', subject: '"Final nudge — complete refill by tomorrow 5pm and receive $25 off with code COMMIT"' },
            ].map(e => (
              <div class="flex gap-3">
                <span class="font-inter text-dark/30 text-xs font-mono w-12 flex-shrink-0">{e.day}</span>
                <span class="font-inter text-dark/60 text-xs">{e.subject}</span>
              </div>
            ))}
            <div class="flex gap-3 border-t border-dark/8 pt-2 mt-2">
              <span class="font-inter text-dark/30 text-xs font-mono w-12 flex-shrink-0">All</span>
              <span class="font-inter text-dark/40 text-xs">Scheduled send: 8:00 AM CT</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 3-Month Timeline -->
      <div id="panel-tl-3mo" class="hidden">
        <div class="bg-white border border-dark/8 rounded-2xl overflow-hidden mb-4">
          <div class="grid grid-cols-12 bg-warm-gray/50 border-b border-dark/8 px-5 py-3">
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-2">Day</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-4">Event</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-3">Status</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-3">Trigger</p>
          </div>
          {[
            { day: 'Day 1', event: 'Purchase — full 3-month charged', status: 'Active', trigger: 'Payment success', hi: false },
            { day: 'Day 2', event: 'MDI approved, sent to pharmacy', status: 'Active – Pending Fulfillment', trigger: 'Clinical approval', hi: false },
            { day: 'Day 7', event: 'Medication received', status: 'Active – In Treatment', trigger: 'Shipment delivered', hi: false },
            { day: 'Day 77', event: 'Auto-renewal warning — 7 days out', status: 'Active', trigger: 'Scheduled', hi: false },
            { day: 'Day 82', event: 'Final auto-renewal reminder — 2 days out', status: 'Active', trigger: 'Scheduled', hi: false },
            { day: 'Day 84', event: '✅ Auto-renewal payment success', status: 'Active – Renewed', trigger: 'invoice.payment_succeeded', hi: false },
            { day: 'Day 84', event: '❌ Auto-renewal payment failure', status: 'Active – Past Due', trigger: 'invoice.payment_failed', hi: true },
            { day: 'Day 84 + 7', event: 'Dunning: update payment method', status: 'Active – Past Due', trigger: 'Scheduled fallback', hi: true },
            { day: 'Day 84 + 14', event: 'Final warning + $50 win-back offer', status: 'Active – Past Due', trigger: 'Scheduled fallback', hi: true },
            { day: 'End of period', event: 'Unresolved payment → Inactive at 11:59 PM CT', status: 'Inactive', trigger: 'System trigger', hi: true },
          ].map(r => (
            <div class={`grid grid-cols-12 px-5 py-3 border-b border-dark/5 last:border-0 ${r.hi ? 'bg-red-50/40' : ''}`}>
              <p class="font-inter text-dark/50 text-xs font-mono col-span-2 self-center">{r.day}</p>
              <p class="font-inter text-dark/70 text-xs col-span-4 self-center">{r.event}</p>
              <p class={`font-inter text-xs font-semibold col-span-3 self-center ${r.status === 'Inactive' ? 'text-dark/40' : r.status === 'Active – Past Due' ? 'text-terracotta' : r.status === 'Active – Renewed' ? 'text-teal' : 'text-teal'}`}>{r.status}</p>
              <p class="font-inter text-dark/30 text-xs col-span-3 self-center font-mono">{r.trigger}</p>
            </div>
          ))}
        </div>
        <div class="bg-terracotta/5 border border-terracotta/15 rounded-xl p-4">
          <p class="font-inter text-dark/60 text-xs font-semibold mb-2">3-Month Email Sequence</p>
          <div class="space-y-1.5">
            {[
              { day: 'Day 77', subject: '"Your 3-month subscription renews in 7 days on [date]. No action needed."' },
              { day: 'Day 82', subject: '"Final reminder — subscription renews in 2 days. Cancel before midnight to avoid renewal."' },
              { day: 'Day 84', subject: '✅ "Payment confirmed — your next 3 months are locked in." OR ❌ "Payment failed — we\'ll retry automatically."' },
              { day: '+7 fail', subject: '"We\'re still having trouble with your payment. Please add a new payment method."' },
              { day: '+14 fail', subject: '"Your account will become inactive at end of billing period. Renew now and get $50 off."' },
            ].map(e => (
              <div class="flex gap-3">
                <span class="font-inter text-dark/30 text-xs font-mono w-14 flex-shrink-0">{e.day}</span>
                <span class="font-inter text-dark/60 text-xs">{e.subject}</span>
              </div>
            ))}
            <div class="flex gap-3 border-t border-dark/8 pt-2 mt-2">
              <span class="font-inter text-dark/30 text-xs font-mono w-14 flex-shrink-0">Timing</span>
              <span class="font-inter text-dark/40 text-xs">Renewal emails: 8:00 AM CT. Post-charge & dunning: within 1 hour of Stripe webhook.</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 6-Month Timeline -->
      <div id="panel-tl-6mo" class="hidden">
        <div class="bg-white border border-dark/8 rounded-2xl overflow-hidden mb-4">
          <div class="grid grid-cols-12 bg-warm-gray/50 border-b border-dark/8 px-5 py-3">
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-2">Day</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-4">Event</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-3">Status</p>
            <p class="font-inter text-dark/50 text-xs font-semibold col-span-3">Trigger</p>
          </div>
          {[
            { day: 'Day 1', event: 'Purchase — full 6-month charged', status: 'Active', trigger: 'Payment success', hi: false },
            { day: 'Day 2', event: 'MDI approved, sent to pharmacy', status: 'Active – Pending Fulfillment', trigger: 'Clinical approval', hi: false },
            { day: 'Day 7', event: 'Medication received', status: 'Active – In Treatment', trigger: 'Shipment delivered', hi: false },
            { day: 'Day 161', event: 'Auto-renewal warning — 7 days out', status: 'Active', trigger: 'Scheduled', hi: false },
            { day: 'Day 166', event: 'Final auto-renewal reminder — 2 days out', status: 'Active', trigger: 'Scheduled', hi: false },
            { day: 'Day 168', event: '✅ Auto-renewal payment success', status: 'Active – Renewed', trigger: 'invoice.payment_succeeded', hi: false },
            { day: 'Day 168', event: '❌ Auto-renewal payment failure', status: 'Active – Past Due', trigger: 'invoice.payment_failed', hi: true },
            { day: 'Day 168 + 7', event: 'Dunning: update payment method', status: 'Active – Past Due', trigger: 'Scheduled fallback', hi: true },
            { day: 'Day 168 + 14', event: 'Final warning + $100 win-back offer', status: 'Active – Past Due', trigger: 'Scheduled fallback', hi: true },
            { day: 'End of period', event: 'Unresolved payment → Inactive at 11:59 PM CT', status: 'Inactive', trigger: 'System trigger', hi: true },
          ].map(r => (
            <div class={`grid grid-cols-12 px-5 py-3 border-b border-dark/5 last:border-0 ${r.hi ? 'bg-red-50/40' : ''}`}>
              <p class="font-inter text-dark/50 text-xs font-mono col-span-2 self-center">{r.day}</p>
              <p class="font-inter text-dark/70 text-xs col-span-4 self-center">{r.event}</p>
              <p class={`font-inter text-xs font-semibold col-span-3 self-center ${r.status === 'Inactive' ? 'text-dark/40' : r.status === 'Active – Past Due' ? 'text-terracotta' : r.status === 'Active – Renewed' ? 'text-teal' : 'text-teal'}`}>{r.status}</p>
              <p class="font-inter text-dark/30 text-xs col-span-3 self-center font-mono">{r.trigger}</p>
            </div>
          ))}
        </div>
        <div class="bg-terracotta/5 border border-terracotta/15 rounded-xl p-4">
          <p class="font-inter text-dark/60 text-xs font-semibold mb-2">6-Month Email Sequence</p>
          <div class="space-y-1.5">
            {[
              { day: 'Day 161', subject: '"Your 6-month subscription renews in 7 days on [date]. No action needed."' },
              { day: 'Day 166', subject: '"Final reminder — subscription renews in 2 days. Cancel before midnight to avoid renewal."' },
              { day: 'Day 168', subject: '✅ "Payment confirmed — your next 6 months are locked in." OR ❌ "Payment failed — we\'ll retry."' },
              { day: '+7 fail', subject: '"We\'re still having trouble with your payment. Please add a new payment method."' },
              { day: '+14 fail', subject: '"Your account will become inactive at end of billing period. Renew now and get $100 off."' },
            ].map(e => (
              <div class="flex gap-3">
                <span class="font-inter text-dark/30 text-xs font-mono w-14 flex-shrink-0">{e.day}</span>
                <span class="font-inter text-dark/60 text-xs">{e.subject}</span>
              </div>
            ))}
            <div class="flex gap-3 border-t border-dark/8 pt-2 mt-2">
              <span class="font-inter text-dark/30 text-xs font-mono w-14 flex-shrink-0">Timing</span>
              <span class="font-inter text-dark/40 text-xs">Renewal emails: 8:00 AM CT. Post-charge & dunning: within 1 hour of Stripe webhook.</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── BILLING ─── -->
    <section id="billing" class="mb-16 scroll-mt-8">
      <h2 class="font-fraunces text-2xl font-semibold text-dark mb-6">Billing Rules</h2>

      <div class="space-y-3">

        <div class="bg-white border border-dark/8 rounded-xl p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class={monthly}>Monthly</span>
                <p class="font-inter text-dark font-semibold text-sm">First charge = when provider approves prescription</p>
              </div>
              <p class="font-inter text-dark/55 text-sm leading-relaxed">Card authorized at signup. Charge captured only when the provider creates a recommendation after the initial intake encounter. If auth window expires before the encounter finishes, the system re-authorizes silently. If the card is declined at charge time → enter payment failure flow (subscription valid 30 days).</p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-dark/8 rounded-xl p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class={commitment}>3 / 6-Month</span>
                <p class="font-inter text-dark font-semibold text-sm">First charge = at signup, immediately</p>
              </div>
              <p class="font-inter text-dark/55 text-sm leading-relaxed">Full upfront payment at subscription purchase. If provider determines patient is not suitable after first payment → automatic full refund, Nimbus absorbs the encounter cost. If intake never completed → auto-refund after 7 days. No prescription released until payment is confirmed.</p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-dark/8 rounded-xl p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class={monthly}>Monthly</span>
                <p class="font-inter text-dark font-semibold text-sm">Recurring billing = 28-day cycle, charge at prescription</p>
              </div>
              <p class="font-inter text-dark/55 text-sm leading-relaxed">Billed every 28 days — aligned to 1 shot/week schedule. Next cycle starts from the date of payment, not original signup date. Early check-in shifts the next cycle. No prescription issued if intake is not completed — this is a regulatory requirement, not just policy.</p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-dark/8 rounded-xl p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class={commitment}>3 / 6-Month</span>
                <p class="font-inter text-dark font-semibold text-sm">Recurring billing = not applicable — already paid in full</p>
              </div>
              <p class="font-inter text-dark/55 text-sm leading-relaxed">Commitment users paid upfront. Monthly check-ins still required to release each shipment — but no new charges occur during the term. Commitment clock starts at payment. If check-in missed, shipment for that month is forfeited — they bought 3/6 months of care, not a guaranteed number of vials.</p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-dark/8 rounded-xl p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class={allPlans}>All plans</span>
                <p class="font-inter text-dark font-semibold text-sm">Payment failure → Stripe Smart Retries + dunning sequence</p>
              </div>
