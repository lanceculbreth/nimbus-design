---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Icons" active="icons">
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <!-- Page Header -->
    <div class="mb-12">
      <p class="font-inter text-teal text-sm font-semibold uppercase tracking-[0.12em] mb-3">Nimbus Design</p>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Icons
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        The full Tabler Icons library — <span id="icon-count">5,039</span> outline icons. Click any icon to copy its SVG.
      </p>
    </div>

    <!-- Usage bar -->
    <div class="bg-dark rounded-2xl px-6 py-4 mb-8 flex flex-wrap items-center gap-6 font-inter text-xs">
      <div>
        <span class="text-cream/40">Style</span>
        <span class="text-cream ml-2">Outline, 2px stroke</span>
      </div>
      <div>
        <span class="text-cream/40">Size</span>
        <span class="text-cream ml-2">24 &times; 24</span>
      </div>
      <div>
        <span class="text-cream/40">Color</span>
        <span class="text-cream ml-2">currentColor</span>
      </div>
      <div>
        <span class="text-cream/40">Source</span>
        <a href="https://tabler.io/icons" target="_blank" rel="noopener noreferrer" class="text-teal ml-2 hover:underline">tabler.io/icons</a>
      </div>
    </div>

    <!-- Search + Filters (sticky) -->
    <div class="sticky top-0 z-30 bg-cream pb-4" style="padding-top: 12px;">
      <!-- Search -->
      <div class="relative mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-dark/30">
          <path d="M3 10a7 7 0 1 0 14 0a7 7 0 1 0 -14 0"/><path d="M21 21l-6 -6"/>
        </svg>
        <input
          type="text"
          id="icon-search"
          placeholder="Search 5,039 icons..."
          class="w-full pl-10 pr-20 py-2.5 rounded-xl border border-dark/10 bg-white font-inter text-sm text-dark placeholder:text-dark/30 focus:outline-none focus:border-teal focus:ring-1 focus:ring-teal transition-colors"
        />
        <span id="result-count" class="absolute right-3.5 top-1/2 -translate-y-1/2 font-inter text-[11px] text-dark/30"></span>
      </div>

      <!-- Category Tabs (wrapping) -->
      <div class="flex flex-wrap gap-1.5" id="category-tabs">
        <button data-cat="All" class="cat-tab active px-3 py-1 rounded-full font-inter text-[11px] font-medium transition-colors bg-dark text-cream">All</button>
        <button data-cat="Popular" class="cat-tab px-3 py-1 rounded-full font-inter text-[11px] font-medium transition-colors bg-teal/10 text-teal hover:bg-teal/20">Popular</button>
      </div>
    </div>

    <!-- Icon Grid -->
    <div id="icon-grid" class="mt-4" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(96px, 1fr)); gap: 6px;">
      <div class="font-inter text-sm text-dark/40 col-span-full py-20 text-center">Loading icons...</div>
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden font-inter text-sm text-dark/40 py-20 text-center">
      No icons match your search.
    </div>
  </div>

  <!-- Copy toast -->
  <div id="copy-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-dark text-cream font-inter text-sm px-5 py-3 rounded-full shadow-xl opacity-0 pointer-events-none transition-opacity duration-300 z-50"></div>

  <script is:inline>
    const POPULAR = [
      'home','search','user','settings','heart','star','check','x','plus','minus',
      'arrow-left','arrow-right','arrow-up','arrow-down','chevron-down','chevron-right',
      'mail','phone','message','bell','calendar','clock','eye','eye-off','lock','unlock',
      'download','upload','share','link','external-link','copy','trash','edit','filter',
      'menu','dots','refresh','bookmark','flag','pin','send','photo','camera','video',
      'file','folder','file-text','clipboard','chart-bar','chart-line','trending-up',
      'credit-card','receipt','package','truck','map-pin','building','users','user-plus',
      'shield-check','key','logout','login','info-circle','alert-triangle','help-circle',
      'circle-check','circle-x','loader','bolt','sparkles','brain','pill','stethoscope',
      'activity','weight','flask','dna','robot','cloud','sun','moon','globe','code',
      'terminal','bug','git-branch','database','server','wifi','bluetooth','printer',
      'adjustments','tool','wrench','paint','palette','scissors','gift','tag','percent',
      'at','hash','world','compass','route','layers-linked','layout-dashboard','apps',
    ];

    let allIcons = [];
    let currentCat = 'All';
    let searchQuery = '';
    let categories = [];

    async function init() {
      const res = await fetch('/data/tabler-icons.json');
      allIcons = await res.json();

      // Build category list sorted by count
      const catMap = {};
      allIcons.forEach(i => { catMap[i.c] = (catMap[i.c] || 0) + 1; });
      categories = Object.entries(catMap)
        .sort((a, b) => b[1] - a[1])
        .map(([name, count]) => ({ name, count }));

      // Render category tabs
      const tabsEl = document.getElementById('category-tabs');
      categories.forEach(cat => {
        const btn = document.createElement('button');
        btn.dataset.cat = cat.name;
        btn.className = 'cat-tab px-3 py-1 rounded-full font-inter text-[11px] font-medium transition-colors bg-dark/5 text-dark/40 hover:bg-dark/10 hover:text-dark/60';
        btn.textContent = cat.name + ' ' + cat.count;
        btn.addEventListener('click', () => selectCategory(cat.name));
        tabsEl.appendChild(btn);
      });

      document.getElementById('icon-count').textContent = allIcons.length.toLocaleString();
      renderIcons();
    }

    function selectCategory(cat) {
      currentCat = cat;
      document.querySelectorAll('.cat-tab').forEach(btn => {
        const isActive = btn.dataset.cat === cat;
        const isPopular = btn.dataset.cat === 'Popular';
        if (isActive && isPopular) {
          btn.className = 'cat-tab px-3 py-1 rounded-full font-inter text-[11px] font-medium transition-colors bg-teal text-cream';
        } else if (isActive) {
          btn.className = 'cat-tab px-3 py-1 rounded-full font-inter text-[11px] font-medium transition-colors bg-dark text-cream';
        } else if (isPopular) {
          btn.className = 'cat-tab px-3 py-1 rounded-full font-inter text-[11px] font-medium transition-colors bg-teal/10 text-teal hover:bg-teal/20';
        } else {
          btn.className = 'cat-tab px-3 py-1 rounded-full font-inter text-[11px] font-medium transition-colors bg-dark/5 text-dark/40 hover:bg-dark/10 hover:text-dark/60';
        }
      });
      renderIcons();
    }

    function getFiltered() {
      let filtered = allIcons;
      if (currentCat === 'Popular') {
        const popSet = new Set(POPULAR);
        filtered = allIcons.filter(i => popSet.has(i.n));
        // Sort by POPULAR order
        filtered.sort((a, b) => POPULAR.indexOf(a.n) - POPULAR.indexOf(b.n));
      } else if (currentCat !== 'All') {
        filtered = filtered.filter(i => i.c === currentCat);
      }
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        filtered = filtered.filter(i => i.n.includes(q));
      }
      return filtered;
    }

    function buildIconBtn(icon) {
      const btn = document.createElement('button');
      btn.className = 'group bg-warm-gray rounded-xl p-3 flex flex-col items-center gap-2 hover:bg-dark hover:translate-y-[-1px] transition-all duration-150 cursor-pointer';
      btn.innerHTML =
        '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-dark group-hover:text-cream transition-colors flex-shrink-0">' +
        icon.d.map(d => '<path d="' + d + '"/>').join('') +
        '</svg>' +
        '<span class="font-inter text-[10px] text-dark/40 group-hover:text-cream/60 transition-colors text-center leading-tight truncate w-full">' + icon.n + '</span>';
      btn.addEventListener('click', () => copyIcon(icon));
      return btn;
    }

    function renderIcons() {
      const grid = document.getElementById('icon-grid');
      const empty = document.getElementById('empty-state');
      const countEl = document.getElementById('result-count');

      const filtered = getFiltered();
      countEl.textContent = filtered.length.toLocaleString() + ' icons';

      if (filtered.length === 0) {
        grid.innerHTML = '';
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');

      // Show max 500 at first for perf
      const visible = filtered.slice(0, 500);
      const hasMore = filtered.length > 500;

      const fragment = document.createDocumentFragment();
      visible.forEach(icon => fragment.appendChild(buildIconBtn(icon)));

      if (hasMore) {
        const more = document.createElement('div');
        more.className = 'col-span-full text-center py-6';
        more.innerHTML = '<button id="load-more" class="font-inter text-xs font-medium text-teal bg-teal/10 px-4 py-2 rounded-full hover:bg-teal/20 transition-colors">Show all ' + filtered.length.toLocaleString() + ' icons</button>';
        fragment.appendChild(more);
      }

      grid.innerHTML = '';
      grid.appendChild(fragment);

      if (hasMore) {
        document.getElementById('load-more').addEventListener('click', () => {
          const moreFragment = document.createDocumentFragment();
          filtered.slice(500).forEach(icon => moreFragment.appendChild(buildIconBtn(icon)));
          grid.removeChild(grid.lastChild);
          grid.appendChild(moreFragment);
        });
      }
    }

    function copyIcon(icon) {
      const svg = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        icon.d.map(d => '<path d="' + d + '"/>').join('') +
        '</svg>';
      navigator.clipboard.writeText(svg).then(() => {
        const toast = document.getElementById('copy-toast');
        toast.textContent = 'Copied ' + icon.n;
        toast.style.opacity = '1';
        setTimeout(() => { toast.style.opacity = '0'; }, 1500);
      });
    }

    // Debounced search
    let searchTimeout;
    document.getElementById('icon-search').addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        searchQuery = e.target.value.trim();
        renderIcons();
      }, 150);
    });

    // Tab clicks for static tabs
    document.querySelector('[data-cat="All"]').addEventListener('click', () => selectCategory('All'));
    document.querySelector('[data-cat="Popular"]').addEventListener('click', () => selectCategory('Popular'));

    init();
  </script>
</Layout>
