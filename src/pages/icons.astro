const totalIcons = iconGroups.reduce((sum, g) => sum + g.icons.length, 0);
---

<Layout title="Icons" active="icons" sections={[
  { label: 'Navigation', id: 'navigation' },
  { label: 'Actions', id: 'actions' },
  { label: 'Status', id: 'status-feedback' },
  { label: 'Communication', id: 'communication' },
  { label: 'Users', id: 'users-security' },
  { label: 'Medical', id: 'medical-health' },
  { label: 'Commerce', id: 'commerce-fulfillment' },
  { label: 'Content', id: 'content-media' },
  { label: 'Data', id: 'data-analytics' },
]}>
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <!-- Page Header -->
    <div class="mb-16">
      <p class="font-inter text-teal text-sm font-semibold uppercase tracking-[0.12em] mb-3">Nimbus Design</p>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Icons
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        {totalIcons} outline icons from Tabler Icons, curated for the Nimbus product. Stroke-based, 24&times;24, 2px stroke weight.
      </p>
    </div>

    <!-- Usage Guidelines -->
    <section class="mb-16">
      <div class="bg-dark rounded-3xl p-8 mb-6">
        <p class="font-inter text-cream/40 text-xs font-semibold uppercase tracking-[0.15em] mb-4">Usage</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <p class="font-inter text-cream text-sm font-semibold mb-1">Style</p>
            <p class="font-inter text-cream/60 text-xs leading-[1.6]">Outline only. 2px stroke, round caps and joins. Never mix filled and outline in the same context.</p>
          </div>
          <div>
            <p class="font-inter text-cream text-sm font-semibold mb-1">Sizing</p>
            <p class="font-inter text-cream/60 text-xs leading-[1.6]">Default 24px. Use 20px for compact UI, 16px for inline text. Always use <code class="bg-cream/10 px-1 rounded text-xs">currentColor</code> for stroke.</p>
          </div>
          <div>
            <p class="font-inter text-cream text-sm font-semibold mb-1">Source</p>
            <p class="font-inter text-cream/60 text-xs leading-[1.6]">Tabler Icons (MIT). 4,000+ available at <code class="bg-cream/10 px-1 rounded text-xs">tabler.io/icons</code>. Only add what the product uses.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Icon Groups -->
    {iconGroups.map((group) => (
      <section id={group.category.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-')} class="mb-16">
        <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-6">{group.category}</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 12px;">
          {group.icons.map((icon) => (
            <button
              data-icon-name={icon.name}
              data-icon-paths={icon.paths}
              class="icon-card group bg-warm-gray rounded-2xl p-4 flex flex-col items-center gap-3 hover:bg-dark hover:translate-y-[-2px] transition-all duration-200 cursor-pointer"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-dark group-hover:text-cream transition-colors"
                set:html={icon.paths}
              />
              <span class="font-inter text-[11px] text-dark/50 group-hover:text-cream/60 transition-colors text-center leading-tight">{icon.name}</span>
            </button>
          ))}
        </div>
      </section>
    ))}

  </div>

  <!-- Copy toast -->
  <div id="copy-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-dark text-cream font-inter text-sm px-5 py-3 rounded-full shadow-xl opacity-0 pointer-events-none transition-opacity duration-300 z-50">
    Copied SVG to clipboard
  </div>

  <script is:inline>
    document.querySelectorAll('.icon-card').forEach(card => {
      card.addEventListener('click', () => {
        const paths = card.dataset.iconPaths;
        const name = card.dataset.iconName;
        const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/>${paths}</svg>`;
        navigator.clipboard.writeText(svg).then(() => {
          const toast = document.getElementById('copy-toast');
          toast.textContent = `Copied ${name} SVG`;
          toast.style.opacity = '1';
          setTimeout(() => { toast.style.opacity = '0'; }, 1500);
        });
      });
    });
  </script>
</Layout>
