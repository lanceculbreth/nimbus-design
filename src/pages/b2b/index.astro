---
import Layout from '../../layouts/Layout.astro';

const stats = [
  { value: '$2,400+', label: 'Revenue per patient, per year' },
  { value: '60%', label: 'Administrative time saved' },
  { value: '85%+', label: 'Patient retention rate' },
  { value: '< 2 hrs', label: 'Staff training to launch' },
];

const differentiators = [
  {
    num: '01',
    title: 'Ownership Model',
    body: 'Nimbus owns Lake Hills Pharmacy — NABP-accredited, 503A/503B compliant, licensed in 37 states. Direct fulfillment and testing eliminates third-party intermediaries.',
  },
  {
    num: '02',
    title: 'Revenue Speed',
    body: 'Cash-pay model eliminates insurance billing delays. Live in hours. Staff training under two hours.',
  },
  {
    num: '03',
    title: 'Founder Credibility',
    body: 'Built by Dr. Jobby John, PharmD, FACA — Immediate Past President of the Texas Pharmacy Association and a 20-year compounding pharmacist.',
  },
];

const serviceLines = [
  { name: 'Weight Management', desc: 'GLP-1s: semaglutide, tirzepatide.' },
  { name: 'Peptide Therapy', desc: '700+ compounds including BPC-157, PT-141, NAD+.' },
  { name: 'Hormone Optimization', desc: 'BHRT with lab integration.' },
  { name: 'Longevity & Recovery', desc: 'NAD+, sexual health, performance protocols.' },
];

const onboarding = [
  { step: '1', title: 'Book a demo', body: 'Platform walkthrough plus service-line recommendations for your practice.' },
  { step: '2', title: 'Launch in hours', body: 'Onboarding, staff training, and same-day prescribing capability.' },
  { step: '3', title: 'Grow', body: 'Dashboard tracking for revenue, outcomes, and retention — scales across locations.' },
];

const press = ['GQ', 'The New York Times', "Men's Health", 'Bloomberg', 'Forbes', 'Business Insider'];
---

<Layout title="B2B Overview" active="overview" sections={[
  { label: 'Promise', id: 'promise' },
  { label: 'Why Nimbus', id: 'why' },
  { label: 'Service Lines', id: 'services' },
  { label: 'Onboarding', id: 'onboarding' },
  { label: 'Proof', id: 'proof' },
  { label: 'CTA', id: 'cta' },
]}>
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <!-- Page Header -->
    <div class="mb-16">
      <p class="font-inter text-teal text-sm font-semibold uppercase tracking-[0.12em] mb-3">Nimbus Design &middot; B2B</p>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Providers
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[620px]">
        Nimbus for clinics and multi-location practices. The platform and the pharmacy — so providers can prescribe, fulfill, and grow from one screen.
      </p>
      <a href="https://nimbus-26.vercel.app/providers" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-6 px-4 py-2 rounded-full bg-dark text-cream text-xs font-inter font-medium hover:bg-dark/80 transition-colors">
        View live page
        <span>&rarr;</span>
      </a>
    </div>

    <!-- Brand Promise -->
    <section id="promise" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Brand Promise</h2>
      <div class="bg-dark rounded-3xl p-10 mb-6">
        <p class="font-inter text-cream/40 text-xs font-semibold uppercase tracking-[0.15em] mb-5">The Hero Headline</p>
        <h3 class="font-fraunces text-cream text-[clamp(28px,4vw,48px)] leading-[1.1] tracking-[-0.02em] mb-6">
          Compounded therapies,<br/>inside your clinic.<br/>In a click.
        </h3>
        <p class="font-inter text-cream/70 text-base leading-[1.7] max-w-[580px]">
          We're the platform <em>and</em> the pharmacy. Prescribe from one screen, ship direct to patients, and manage protocols end-to-end — so you can focus on care and grow your practice at the same time.
        </p>
      </div>
      <div class="bg-warm-gray rounded-3xl p-6 flex items-center justify-between">
        <div>
          <p class="font-inter text-dark/40 text-xs font-semibold uppercase tracking-[0.12em] mb-1">Primary CTA</p>
          <p class="font-fraunces text-dark text-lg">Book a demo</p>
        </div>
        <span class="bg-dark text-cream font-inter text-xs font-medium px-4 py-2 rounded-full">No contracts. No platform fees.</span>
      </div>
    </section>

    <!-- Stats Row -->
    <section id="why" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Why Nimbus</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
        {stats.map(s => (
          <div class="bg-teal/10 rounded-2xl p-5">
            <p class="font-fraunces text-dark text-[clamp(22px,2.5vw,32px)] leading-tight tracking-[-0.02em] mb-1.5">{s.value}</p>
            <p class="font-inter text-xs text-dark/60 leading-[1.4]">{s.label}</p>
          </div>
        ))}
      </div>

      <h3 class="font-inter text-dark/40 text-xs font-semibold tracking-[0.15em] uppercase mb-4">Three Core Differentiators</h3>
      <div class="space-y-3">
        {differentiators.map(d => (
          <div class="bg-warm-gray rounded-2xl p-6 flex gap-5">
            <span class="font-fraunces text-teal text-2xl leading-none flex-shrink-0">{d.num}</span>
            <div>
              <p class="font-inter text-sm font-semibold text-dark mb-1.5">{d.title}</p>
              <p class="font-inter text-sm text-dark/60 leading-[1.6]">{d.body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Service Lines -->
    <section id="services" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-4">Four Service Lines</h2>
      <p class="font-inter text-dark/50 text-sm mb-8">Ready-to-prescribe protocols across the four Nimbus program pillars.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {serviceLines.map(s => (
          <div class="bg-warm-gray rounded-2xl p-6">
            <p class="font-inter text-sm font-semibold text-dark mb-1">{s.name}</p>
            <p class="font-inter text-sm text-dark/60 leading-[1.6]">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Onboarding -->
    <section id="onboarding" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Partner Onboarding</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {onboarding.map(o => (
          <div class="bg-dark rounded-3xl p-7">
            <p class="font-inter text-teal text-xs font-semibold uppercase tracking-[0.12em] mb-4">Step {o.step}</p>
            <p class="font-fraunces text-cream text-xl leading-tight mb-3">{o.title}</p>
            <p class="font-inter text-cream/60 text-sm leading-[1.6]">{o.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Proof -->
    <section id="proof" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Proof</h2>

      <!-- Testimonial -->
      <div class="bg-dark rounded-3xl p-10 mb-6">
        <p class="font-inter text-cream/40 text-xs font-semibold uppercase tracking-[0.15em] mb-5">Testimonial</p>
        <p class="font-fraunces text-cream text-xl leading-[1.5] tracking-[-0.01em] mb-6">
          &ldquo;We added peptides across all three locations in one afternoon. Front desk staff stopped chasing the pharmacy. Patients started asking what else we offered. It paid for itself in six weeks.&rdquo;
        </p>
        <div class="border-t border-cream/10 pt-5">
          <p class="font-inter text-cream text-sm font-medium">Dr. Marcus Reyes</p>
          <p class="font-inter text-cream/50 text-xs">Multi-clinic operator, Southeast</p>
        </div>
      </div>

      <!-- Press -->
      <div class="bg-warm-gray rounded-3xl p-6">
        <p class="font-inter text-dark/40 text-xs font-semibold uppercase tracking-[0.12em] mb-4">Featured In</p>
        <div class="flex flex-wrap gap-2">
          {press.map(p => (
            <span class="bg-cream text-dark font-inter text-xs font-medium px-3 py-1.5 rounded-full border border-dark/8">{p}</span>
          ))}
        </div>
      </div>

      <!-- Compliance line -->
      <div class="mt-4 font-inter text-[11px] text-dark/40 leading-[1.6]">
        503A / 503B compliant. NABP-accredited. Licensed in 37 states.
      </div>
    </section>

    <!-- Closing CTA -->
    <section id="cta" class="mb-20">
      <div class="bg-teal rounded-3xl p-10 text-center">
        <h3 class="font-fraunces text-cream text-[clamp(26px,3.5vw,40px)] leading-[1.1] tracking-[-0.02em] mb-4">Book a 20-minute demo</h3>
        <p class="font-inter text-cream/80 text-sm mb-6">No contracts. No platform fees to try it.</p>
        <a href="https://nimbus-26.vercel.app/providers" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-cream text-dark text-sm font-inter font-medium hover:bg-cream/90 transition-colors">
          Book a demo
          <span>&rarr;</span>
        </a>
      </div>
    </section>

  </div>
</Layout>
