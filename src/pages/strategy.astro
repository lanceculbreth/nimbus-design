---
import Layout from '../layouts/Layout.astro';

const BE = 'inline-flex items-center px-2 py-0.5 rounded-full bg-teal/10 text-teal text-xs font-semibold';
const BS = 'inline-flex items-center px-2 py-0.5 rounded-full bg-terracotta/10 text-terracotta text-xs font-semibold';
const BP = 'inline-flex items-center px-2 py-0.5 rounded-full bg-dark/8 text-dark/60 text-xs font-semibold';
const GT = 'inline-flex items-center px-2.5 py-1 rounded-lg bg-warm-gray text-dark/40 text-xs font-medium whitespace-nowrap';

const sections = [
  { label: 'Overview', id: 'overview' },
  { label: 'Onboarding', id: 'onboarding' },
  { label: 'Encounter', id: 'encounter' },
  { label: 'Fulfillment', id: 'fulfillment' },
  { label: 'Refill Cycle', id: 'refill' },
  { label: 'Edge Cases', id: 'edge-cases' },
  { label: 'Engagement', id: 'engagement' },
  { label: 'Channel Rules', id: 'channel-rules' },
];
---

<Layout title="CX Strategy" active="strategy" sections={sections}>
  <div class="max-w-[860px] mx-auto px-10 py-16">

    <!-- Page Header -->
    <div class="mb-14">
      <p class="font-inter text-teal text-xs font-semibold tracking-widest uppercase mb-3">WeightWise</p>
      <h1 class="font-fraunces text-4xl font-semibold text-dark leading-tight mb-4">Notification Strategy</h1>
      <p class="font-inter text-dark/50 text-lg leading-relaxed max-w-[580px]">
        The complete communication journey — every email, SMS, and push notification across the subscriber lifecycle, in the order a patient experiences them.
      </p>
    </div>

    <!-- Overview / Stats -->
    <section id="overview" class="mb-16 scroll-mt-8">
      <div class="grid grid-cols-4 gap-4 mb-10">
        <div class="bg-white rounded-2xl border border-dark/8 p-5">
          <p class="font-inter text-dark/40 text-xs font-medium uppercase tracking-wider mb-2">Total Touchpoints</p>
          <p class="font-fraunces text-3xl font-semibold text-dark">58</p>
        </div>
        <div class="bg-teal/8 rounded-2xl border border-teal/15 p-5">
          <p class="font-inter text-teal/70 text-xs font-medium uppercase tracking-wider mb-2">Emails</p>
          <p class="font-fraunces text-3xl font-semibold text-teal">49</p>
        </div>
        <div class="bg-terracotta/8 rounded-2xl border border-terracotta/15 p-5">
          <p class="font-inter text-terracotta/70 text-xs font-medium uppercase tracking-wider mb-2">SMS</p>
          <p class="font-fraunces text-3xl font-semibold text-terracotta">28</p>
        </div>
        <div class="bg-dark/5 rounded-2xl border border-dark/8 p-5">
          <p class="font-inter text-dark/40 text-xs font-medium uppercase tracking-wider mb-2">Push</p>
          <p class="font-fraunces text-3xl font-semibold text-dark/70">25</p>
        </div>
      </div>

      <!-- Channel legend -->
      <div class="flex items-center gap-6 mb-6">
        <p class="font-inter text-dark/40 text-xs font-medium uppercase tracking-wider">Channels</p>
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-teal/10 text-teal text-xs font-semibold">
            <span class="w-1.5 h-1.5 rounded-full bg-teal inline-block"></span>Email
          </span>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-terracotta/10 text-terracotta text-xs font-semibold">
            <span class="w-1.5 h-1.5 rounded-full bg-terracotta inline-block"></span>SMS
          </span>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-dark/8 text-dark/60 text-xs font-semibold">
            <span class="w-1.5 h-1.5 rounded-full bg-dark/50 inline-block"></span>Push
          </span>
        </div>
      </div>

      <!-- Phase summary table -->
      <div class="bg-white rounded-2xl border border-dark/8 overflow-hidden">
        <div class="grid grid-cols-5 gap-0 bg-warm-gray/50 px-5 py-3 border-b border-dark/8">
          <p class="font-inter text-dark/50 text-xs font-semibold col-span-2">Phase</p>
          <p class="font-inter text-teal text-xs font-semibold text-center">Email</p>
          <p class="font-inter text-terracotta text-xs font-semibold text-center">SMS</p>
          <p class="font-inter text-dark/50 text-xs font-semibold text-center">Push</p>
        </div>
        {[
          { phase: 'Onboarding', anchor: 'onboarding', email: 10, sms: 5, push: 4 },
          { phase: 'Provider Encounter', anchor: 'encounter', email: 3, sms: 2, push: 3 },
          { phase: 'Order & Fulfillment', anchor: 'fulfillment', email: 5, sms: 4, push: 3 },
          { phase: 'Refill Cycle', anchor: 'refill', email: 3, sms: 3, push: 3 },
          { phase: 'Awaiting Check-in (Monthly)', anchor: 'edge-cases', email: 4, sms: 3, push: 3 },
          { phase: 'Shipment Held (3/6-mo)', anchor: 'edge-cases', email: 4, sms: 3, push: 3 },
          { phase: 'Payment Failure', anchor: 'edge-cases', email: 7, sms: 6, push: 4 },
          { phase: 'Cancellation', anchor: 'edge-cases', email: 4, sms: 0, push: 0 },
          { phase: 'Medication Switch', anchor: 'edge-cases', email: 2, sms: 1, push: 1 },
          { phase: 'Plan Changes', anchor: 'edge-cases', email: 3, sms: 0, push: 0 },
          { phase: 'Subscription Restart', anchor: 'edge-cases', email: 1, sms: 1, push: 0 },
          { phase: 'Proactive Engagement', anchor: 'engagement', email: 3, sms: 0, push: 1 },
        ].map((row, i) => (
          <a href={`#${row.anchor}`} class="grid grid-cols-5 gap-0 px-5 py-3 border-b border-dark/5 last:border-b-0 hover:bg-warm-gray/40 transition-colors cursor-pointer">
            <p class="font-inter text-dark text-sm col-span-2">{row.phase}</p>
            <p class="font-inter text-teal text-sm font-medium text-center">{row.email}</p>
            <p class="font-inter text-terracotta text-sm font-medium text-center">{row.sms > 0 ? row.sms : '—'}</p>
            <p class="font-inter text-dark/50 text-sm font-medium text-center">{row.push > 0 ? row.push : '—'}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ─── PHASE 1: ONBOARDING ─── -->
    <section id="onboarding" class="mb-16 scroll-mt-8">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-7 h-7 rounded-full bg-teal flex items-center justify-center flex-shrink-0">
          <span class="font-inter text-white text-xs font-bold">1</span>
        </div>
        <h2 class="font-fraunces text-2xl font-semibold text-dark">Onboarding</h2>
      </div>
      <p class="font-inter text-dark/50 text-sm leading-relaxed mb-8 ml-10">
        From quiz completion to intake submitted. Highest-leverage conversion phase — every drop-off has a recovery sequence.
      </p>

      <div class="space-y-3 ml-4">

        <div class="phase-divider font-inter text-dark/30 text-xs font-semibold uppercase tracking-widest py-2 border-b border-dark/8 mb-4">Quiz Abandonment</div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_02 + 30min</span>
                <span class={BP}>Push</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Quiz Abandonment Nudge</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Your personalized weight loss plan is ready — create your account to get started."</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Convert quiz → account</span>
            </div>
          </div>
        </div>

        <div class="phase-divider font-inter text-dark/30 text-xs font-semibold uppercase tracking-widest py-2 border-b border-dark/8 mb-4 mt-6">Email Verification</div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_03 — Immediate</span>
                <span class={BE}>Email</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Verify Your Email</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Verify your email to get started with Weightwise" — non-blocking; users can proceed to purchase without verifying.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Security / account ownership</span>
            </div>
          </div>
        </div>

        <div class="phase-divider font-inter text-dark/30 text-xs font-semibold uppercase tracking-widest py-2 border-b border-dark/8 mb-4 mt-6">Account Created → Subscription</div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_03 + 1hr</span>
                <span class={BE}>Email</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Welcome + Complete Signup</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Welcome to Weightwise — let's get you started." You're one step away from starting your personalized journey.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Account → paid subscription</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_03 + 24hr</span>
                <span class={BE}>Email</span>
                <span class={BS}>SMS</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Subscription Reminder #1</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">Email: "Don't miss out on your Weightwise plan" · SMS: "Your plan is waiting. Complete your subscription today."</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Reduce account → purchase drop-off</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_03 + 72hr</span>
                <span class={BE}>Email</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Subscription Reminder #2</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Still thinking about Weightwise?" — Patients who start within the first week see the best results.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Final conversion push</span>
            </div>
          </div>
        </div>

        <div class="phase-divider font-inter text-dark/30 text-xs font-semibold uppercase tracking-widest py-2 border-b border-dark/8 mb-4 mt-6">Subscription Purchased → Intake</div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_04 — Immediate</span>
                <span class={BE}>Email</span>
                <span class={BS}>SMS</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Subscription Confirmation</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">Plan is active. Monthly: no charge until provider prescribes. 3/6-mo: first payment processed. Complete intake to begin.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Confirm purchase, drive intake</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_04 + 4hr</span>
                <span class={BP}>Push</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Intake Reminder #1</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Your provider is waiting. Complete your intake to start your Weightwise treatment."</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Prompt same-day intake</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_04 + 24hr</span>
                <span class={BE}>Email</span>
                <span class={BS}>SMS</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Intake Reminder #2</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Complete your intake to begin treatment" — your health information and ID verification is needed before provider assignment.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Drive intake for paying customers</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_04 + 72hr</span>
                <span class={BE}>Email</span>
                <span class={BS}>SMS</span>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 text-xs font-semibold border border-amber-200">3/6-mo only</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Intake Urgency (Commitment Plan)</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Your Weightwise shipment is pending your intake" — payment has been processed but treatment can't begin until intake is done.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Recover stalled paid users</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_04 + 7 days</span>
                <span class={BE}>Email</span>
                <span class={BS}>SMS</span>
                <span class={BP}>Push</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Intake Final Warning</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"We don't want you to miss out, [First Name]" — it's been a week. Complete intake or contact support. Last push before CS outreach.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Last chance before CS escalation</span>
            </div>
          </div>
        </div>

        <div class="phase-divider font-inter text-dark/30 text-xs font-semibold uppercase tracking-widest py-2 border-b border-dark/8 mb-4 mt-6">Intake Complete</div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ONB_05 — Immediate</span>
                <span class={BE}>Email</span>
                <span class={BP}>Push</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Intake Complete Confirmation</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Intake received — your provider is being assigned." Push: "Intake submitted! A provider will review your case shortly."</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Confirm intake, set encounter expectation</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── PHASE 2: PROVIDER ENCOUNTER ─── -->
    <section id="encounter" class="mb-16 scroll-mt-8">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-7 h-7 rounded-full bg-teal flex items-center justify-center flex-shrink-0">
          <span class="font-inter text-white text-xs font-bold">2</span>
        </div>
        <h2 class="font-fraunces text-2xl font-semibold text-dark">Provider Encounter</h2>
      </div>
      <p class="font-inter text-dark/50 text-sm leading-relaxed mb-8 ml-10">
        Asynchronous MDI encounter via provider chat. When ENC_03 completes, the system moves quickly through RX_01 → RX_02 → RX_03 — so a single push fires at encounter end and one consolidated email goes out at order placement.
      </p>

      <div class="space-y-3 ml-4">

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ENC_01 — Immediate</span>
                <span class={BE}>Email</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Case Created</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Your provider consultation is being prepared" — bridges the wait between intake and encounter starting.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Bridge wait, set expectation</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ENC_02 — Immediate</span>
                <span class={BE}>Email</span>
                <span class={BS}>SMS</span>
                <span class={BP}>Push</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Encounter Started</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Your provider is ready — start your consultation." All three channels fire simultaneously when the provider begins the encounter.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Drive immediate portal engagement</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ENC_02 + 24hr</span>
                <span class={BP}>Push</span>
                <span class={BS}>SMS</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Encounter Response Reminder</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">Only fires if user has unread provider messages. Push + SMS to bring them back to the portal chat.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Prevent encounter stalling</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ENC_02 + 48hr</span>
                <span class={BE}>Email</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Encounter Urgency Reminder</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Your provider is waiting for your response" — escalates to email if still unread at 48hr mark.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Prevent encounter timeout</span>
            </div>
          </div>
        </div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">ENC_03 — Immediate</span>
                <span class={BP}>Push</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Provider Consultation Complete</p>
              <p class="font-inter text-dark/50 text-xs leading-relaxed">"Great news! Your provider has prescribed your treatment. Details coming via email." — immediate positive signal while consolidated email is prepared.</p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class={GT}>Immediate positive signal</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── PHASE 3: ORDER & FULFILLMENT ─── -->
    <section id="fulfillment" class="mb-16 scroll-mt-8">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-7 h-7 rounded-full bg-teal flex items-center justify-center flex-shrink-0">
          <span class="font-inter text-white text-xs font-bold">3</span>
        </div>
        <h2 class="font-fraunces text-2xl font-semibold text-dark">Order & Fulfillment</h2>
      </div>
      <p class="font-inter text-dark/50 text-sm leading-relaxed mb-8 ml-10">
        Internal pharmacy states ORD_01–03 are not user-facing (surface in portal tracker only). First patient notification is the consolidated confirmation at RX_03, then shipped/delivered updates.
      </p>

      <div class="space-y-3 ml-4">

        <div class="phase-divider font-inter text-dark/30 text-xs font-semibold uppercase tracking-widest py-2 border-b border-dark/8 mb-4">Consolidated Confirmation (replaces 3 separate emails)</div>

        <div class="notif-card bg-white rounded-xl border border-dark/8 p-4 hover:border-dark/15 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="font-inter text-dark/30 text-xs font-mono">RX_03 — Monthly</span>
                <span class={BE}>Email</span>
                <span class={BS}>SMS</span>
              </div>
              <p class="font-inter text-dark text-sm font-semibold mb-1">Treatment Prescribed + Payment + Order Confirmed</p>
