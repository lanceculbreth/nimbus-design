        </div>

        <!-- Frequency caps & quiet hours -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white rounded-2xl border border-dark/8 p-5">
            <h3 class="font-inter text-dark text-sm font-semibold mb-4">Frequency Caps</h3>
            <div class="space-y-2">
              <div class="flex items-center justify-between">
                <span class="font-inter text-dark/50 text-xs">SMS per day</span>
                <span class="font-inter text-terracotta font-semibold text-sm">Max 2</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="font-inter text-dark/50 text-xs">Push per day</span>
                <span class="font-inter text-dark/70 font-semibold text-sm">Max 3</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="font-inter text-dark/50 text-xs">Email per day</span>
                <span class="font-inter text-teal font-semibold text-sm">No cap*</span>
              </div>
              <p class="font-inter text-dark/30 text-xs pt-2">*Avoid more than 2 non-transactional emails per day. Caps may be relaxed during active escalation sequences.</p>
            </div>
          </div>
          <div class="bg-white rounded-2xl border border-dark/8 p-5">
            <h3 class="font-inter text-dark text-sm font-semibold mb-4">Quiet Hours</h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-terracotta flex-shrink-0"></div>
                <div>
                  <p class="font-inter text-dark/70 text-xs font-medium">SMS & Push</p>
                  <p class="font-inter text-dark/40 text-xs">No sends 9:00 PM — 8:00 AM (user's local timezone). Queue for 8:00 AM if triggered during quiet hours.</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-teal flex-shrink-0"></div>
                <div>
                  <p class="font-inter text-dark/70 text-xs font-medium">Email</p>
                  <p class="font-inter text-dark/40 text-xs">No quiet hour restrictions — users control their own notification settings.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Unsubscribe rules -->
        <div class="bg-white rounded-2xl border border-dark/8 p-5">
          <h3 class="font-inter text-dark text-sm font-semibold mb-4">Unsubscribe & Opt-out Rules</h3>
          <div class="grid grid-cols-2 gap-6">
            <div>
              <p class="font-inter text-dark/50 text-xs font-semibold uppercase tracking-wider mb-2">Cannot Unsubscribe</p>
              <p class="font-inter text-dark/60 text-xs leading-relaxed">Payment confirmations, shipping updates, status changes — these are service-essential transactional notifications.</p>
            </div>
            <div>
              <p class="font-inter text-dark/50 text-xs font-semibold uppercase tracking-wider mb-2">Requires Unsubscribe Option</p>
              <p class="font-inter text-dark/60 text-xs leading-relaxed">Milestones, feedback surveys, plan upgrade suggestions. SMS opt-out must support STOP keyword (TCPA requirement).</p>
            </div>
          </div>
        </div>

      </div>
    </section>

  </div>
</Layout>


<script is:inline>
  function switchEdge(active) {
    const tabs = ['awaiting','held','payment','cancel','medswitch','planchange','restart'];
    tabs.forEach(id => {
      const panel = document.getElementById('panel-' + id);
      const btn = document.querySelector(`[data-edge="${id}"]`);
      if (id === active) {
        panel.classList.remove('hidden');
        btn.className = 'edge-tab px-4 py-2 rounded-full text-sm font-medium transition-all bg-dark text-cream';
      } else {
        panel.classList.add('hidden');
        btn.className = 'edge-tab px-4 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark';
      }
    });
  }
</script>
