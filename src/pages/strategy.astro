          </div>
        </div>

      </div>
    </section>

    <!-- ─── CHANNEL RULES ─── -->
    <section id="channel-rules" class="mb-16 scroll-mt-8">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="font-fraunces text-2xl font-semibold text-dark">Channel Rules & Frequency Caps</h2>
      </div>

      <div class="ml-4 space-y-8">

        <!-- Channel escalation pattern -->
        <div>
          <h3 class="font-inter text-dark text-sm font-semibold mb-4">Escalation Pattern</h3>
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2 bg-dark/5 rounded-xl px-4 py-3 flex-1">
              <span class={BP}>Push</span>
              <span class="font-inter text-dark/60 text-xs">for immediacy</span>
            </div>
            <span class="font-inter text-dark/30 text-sm">→</span>
            <div class="flex items-center gap-2 bg-teal/8 rounded-xl px-4 py-3 flex-1">
              <span class={BE}>Email</span>
              <span class="font-inter text-dark/60 text-xs">for detail</span>
            </div>
            <span class="font-inter text-dark/30 text-sm">→</span>
            <div class="flex items-center gap-2 bg-terracotta/8 rounded-xl px-4 py-3 flex-1">
              <span class={BS}>SMS</span>
              <span class="font-inter text-dark/60 text-xs">for urgency</span>
            </div>
          </div>
        </div>

        <!-- Channel matrix -->
        <div>
          <h3 class="font-inter text-dark text-sm font-semibold mb-4">Channel Selection Matrix</h3>
          <div class="bg-white rounded-2xl border border-dark/8 overflow-hidden">
            <div class="grid grid-cols-4 gap-0 bg-warm-gray/50 px-5 py-3 border-b border-dark/8">
              <p class="font-inter text-dark/50 text-xs font-semibold col-span-1">Notification Type</p>
              <p class="font-inter text-teal text-xs font-semibold text-center">Email</p>
              <p class="font-inter text-terracotta text-xs font-semibold text-center">SMS</p>
              <p class="font-inter text-dark/50 text-xs font-semibold text-center">Push</p>
            </div>
            {[
              { type: 'Confirmations (purchase, order, delivery)', email: 'Always', sms: 'Key events only', push: 'Always' },
              { type: 'Action required (check-in, payment)', email: 'Always', sms: 'Day −5 onward', push: 'Always' },
              { type: 'Status changes (paused, held, inactive)', email: 'Always', sms: 'Critical only', push: 'Yes' },
              { type: 'Reminders / nudges', email: 'Yes', sms: 'Selectively', push: 'Yes' },
              { type: 'Celebrations / milestones', email: 'Yes', sms: '—', push: 'Optional' },
              { type: 'Feedback / surveys', email: 'Yes', sms: '—', push: '—' },
            ].map(row => (
              <div class="grid grid-cols-4 gap-0 px-5 py-3 border-b border-dark/5 last:border-b-0">
                <p class="font-inter text-dark/70 text-xs col-span-1 pr-4">{row.type}</p>
                <p class="font-inter text-teal/80 text-xs text-center">{row.email}</p>
                <p class="font-inter text-terracotta/80 text-xs text-center">{row.sms}</p>
                <p class="font-inter text-dark/50 text-xs text-center">{row.push}</p>
              </div>
            ))}
