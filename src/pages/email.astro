---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    name: 'Onboarding',
    description: 'Patient sign-up through first delivery',
    emails: [
      { name: 'Welcome', slug: 'welcome', subject: 'Welcome, {{FIRST_NAME}} — let\'s find your groove', tags: ['Hero'], isNew: false },
      { name: 'Payment Confirmed', slug: 'payment-confirmed', subject: 'You\'re all set — here\'s your plan', tags: ['Hero'], isNew: false },
      { name: 'Prescription Confirmed', slug: 'prescription-confirmed', subject: 'Great news — your treatment is approved', tags: ['Hero'], isNew: false },
      { name: 'Treatment Shipped', slug: 'treatment-shipped', subject: 'Your treatment is on its way', tags: ['Hero'], isNew: false },
      { name: 'Treatment Delivered', slug: 'treatment-delivered', subject: 'It\'s here — let\'s get started', tags: ['Hero'], isNew: true },
      { name: 'Email Verification', slug: 'email-verification', subject: 'Verify your email to get started', tags: ['Trust'], isNew: false },
    ]
  },
  {
    name: 'Refill & Check-in',
    description: 'Monthly cycle notifications and check-in reminders',
    emails: [
      { name: 'Refill Heads Up', slug: 'refill-heads-up', subject: 'Heads up — your check-in opens soon', tags: ['Inline img'], isNew: true },
      { name: 'Check-in Trigger', slug: 'check-in-trigger', subject: 'Your 60-second check-in is ready', tags: ['Inline img'], isNew: false },
      { name: 'Reminder 1 (Gentle)', slug: 'reminder-1', subject: 'Just a gentle nudge, {{FIRST_NAME}}', tags: ['Trust'], isNew: false },
      { name: 'Reminder 2 (Direct)', slug: 'reminder-2', subject: 'Your check-in is still waiting', tags: ['Trust'], isNew: false },
      { name: 'Reminder 3 (Final)', slug: 'reminder-3', subject: 'We don\'t want you to miss your refill', tags: ['Trust'], isNew: false },
      { name: 'Refill Confirmation', slug: 'refill-confirmation', subject: 'Check-in received — you\'re all set', tags: ['Trust'], isNew: true },
    ]
  },
  {
    name: 'Retention',
    description: 'Incomplete registration and payment recovery sequences',
    emails: [
      { name: 'Incomplete Registration 1', slug: 'incomplete-registration-1', subject: 'You\'re almost there, {{FIRST_NAME}}', tags: ['Trust'], isNew: false },
      { name: 'Incomplete Registration 2', slug: 'incomplete-registration-2', subject: 'Still thinking about it?', tags: ['Trust'], isNew: false },
      { name: 'Incomplete Payment 1', slug: 'incomplete-payment-1', subject: 'Almost there — finish your enrollment', tags: ['Trust'], isNew: false },
      { name: 'Incomplete Payment 2', slug: 'incomplete-payment-2', subject: 'Your WeightWise plan is waiting', tags: ['Trust'], isNew: false },
      { name: 'Incomplete Payment 3', slug: 'incomplete-payment-3', subject: 'We\'re here if you need us', tags: ['Trust'], isNew: false },
      { name: 'Recommendation Reminder 1', slug: 'recommendation-reminder-1', subject: 'Your personalized plan is ready', tags: ['Trust'], isNew: false },
      { name: 'Recommendation Reminder 2', slug: 'recommendation-reminder-2', subject: 'Still interested? Let\'s talk about your options', tags: ['Trust'], isNew: false },
      { name: 'Recommendation Reminder 3', slug: 'recommendation-reminder-3', subject: 'Your recommendation expires soon', tags: ['Trust'], isNew: false },
    ]
  },
  {
    name: 'Lifecycle & Billing',
    description: 'Payment, subscription, and referral management',
    emails: [
      { name: 'Payment Received', slug: 'payment-received', subject: 'Payment received — thank you', tags: ['Trust'], isNew: false },
      { name: 'Payment Failed', slug: 'payment-failed', subject: 'Heads up — your payment didn\'t go through', tags: ['Trust'], isNew: true },
      { name: 'Subscription Paused', slug: 'subscription-paused', subject: 'Your plan is paused — no worries', tags: ['Trust'], isNew: false },
      { name: 'Subscription Resumed', slug: 'subscription-resumed', subject: 'Welcome back — your plan is active again', tags: ['Trust'], isNew: false },
      { name: 'Cancellation Confirmation', slug: 'cancellation-confirmation', subject: 'Your subscription has been cancelled', tags: ['Trust'], isNew: true },
      { name: 'Renewal Reminder', slug: 'renewal-reminder', subject: 'Your next payment is coming up', tags: ['Trust'], isNew: true },
      { name: 'Plan Change', slug: 'plan-change', subject: 'Your plan has been updated', tags: ['Trust'], isNew: false },
      { name: 'Referral Invitation', slug: 'referral-invitation', subject: 'Share the groove', tags: ['Trust'], isNew: false },
      { name: 'Referral Coupon Earned', slug: 'referral-coupon-earned', subject: 'You earned a discount', tags: ['Trust'], isNew: false },
    ]
  },
  {
    name: 'Clinical',
    description: 'Provider decisions, medication updates, and escalations',
    emails: [
      { name: 'Prescription Denied', slug: 'prescription-denied', subject: 'An update on your treatment review', tags: ['Trust'], isNew: true },
      { name: 'Medication Switch Result', slug: 'medication-switch-result', subject: 'Update on your medication switch request', tags: ['Trust'], isNew: true },
      { name: 'Dose Change Confirmation', slug: 'dose-change-confirmation', subject: 'Your dose has been adjusted', tags: ['Inline img'], isNew: true },
      { name: 'Red Flag Escalation', slug: 'red-flag-escalation', subject: 'Important — your care team is reviewing your report', tags: ['Trust'], isNew: true },
    ]
  },
  {
    name: 'Winback',
    description: 'Post-cancellation re-engagement campaigns',
    emails: [
      { name: 'Winback — Day 14', slug: 'winback-day-14', subject: 'We saved your spot', tags: ['Hero'], isNew: true },
      { name: 'Winback — Day 30', slug: 'winback-day-30', subject: 'Still thinking about it?', tags: ['Hero'], isNew: true },
      { name: 'Winback — Day 60', slug: 'winback-day-60', subject: 'The door is always open', tags: ['Hero'], isNew: true },
    ]
  },
  {
    name: 'Milestones & Feedback',
    description: 'Celebrations, progress markers, and satisfaction surveys',
    emails: [
      { name: 'Milestone — 1 Month', slug: 'milestone-1-month', subject: 'One month in — look at you go!', tags: ['Hero'], isNew: true },
      { name: 'Milestone — 3 Months', slug: 'milestone-3-months', subject: 'Three months of steady rhythm', tags: ['Hero'], isNew: true },
      { name: 'Milestone — 6 Months', slug: 'milestone-6-months', subject: 'Six months — this is who you are now', tags: ['Hero'], isNew: true },
      { name: 'NPS Survey', slug: 'nps-survey', subject: 'Quick question — how are we doing?', tags: ['Inline img'], isNew: true },
    ]
  },
];

const totalEmails = categories.reduce((sum, cat) => sum + cat.emails.length, 0);
---

<Layout title="Customer Touchpoints" active="email">
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <!-- Page Header -->
    <div class="mb-10">
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Customer Touchpoints
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        The full communications journey — email, SMS, and in-app notifications designed to guide patients from first touchpoint through long-term retention.
      </p>
    </div>

    <!-- Tabs -->
    <div class="flex items-center gap-2 mb-12" id="cx-tabs">
      <!-- Product selectors -->
      <button onclick="switchProduct('weightwise')" id="prod-weightwise" class="px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark text-cream">WeightWise</button>
      <button onclick="switchProduct('nimcore')" id="prod-nimcore" class="px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark">NimCore</button>
      <!-- Separator -->
      <div class="w-px h-5 bg-dark/15 mx-1"></div>
      <!-- Channel tabs -->
      <button onclick="switchTab('emails')" id="tab-emails" class="px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark">Emails</button>
      <button onclick="switchTab('sms')" id="tab-sms" class="px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark">SMS</button>
      <button onclick="switchTab('notifications')" id="tab-notifications" class="px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark">Notifications</button>
      <button onclick="switchTab('journey')" id="tab-journey" class="px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark">CX Journey</button>
    </div>

    <!-- Tab: Emails -->
    <div id="panel-emails">

    <!-- Categories -->
    {categories.map((cat) => (
      <section class="mb-12">
        <div class="mb-5">
          <h2 class="font-fraunces text-dark text-xl tracking-[-0.02em] mb-1">{cat.name}</h2>
          <p class="font-inter text-dark/40 text-sm">{cat.description}</p>
        </div>

        <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
          {cat.emails.map((email) => (
            <div
              class="email-card group bg-white rounded-xl border border-dark/8 overflow-hidden cursor-pointer hover:-translate-y-1 hover:shadow-lg hover:border-teal/25 transition-all duration-250"
              data-name={email.name}
              data-slug={email.slug}
            >
              <!-- Preview thumbnail -->
              <div class="h-[160px] bg-warm-gray/30 border-b border-dark/5 overflow-hidden pointer-events-none">
                <iframe src={`/emails/${email.slug}.html`} class="w-[600px] h-[800px] border-0 origin-top-left scale-[0.44] pointer-events-none" tabindex="-1" loading="lazy"></iframe>
              </div>

              <!-- Card content -->
              <div class="p-4">
                <div class="flex items-start justify-between gap-2 mb-2">
                  <h3 class="font-inter text-dark text-sm font-semibold leading-snug">{email.name}</h3>
                  {email.isNew && (
                    <span class="flex-shrink-0 inline-block px-2 py-0.5 rounded-full bg-terracotta/10 text-terracotta text-[10px] font-bold uppercase tracking-wider">NEW</span>
                  )}
                </div>
                <p class="font-inter text-dark/40 text-xs leading-relaxed line-clamp-2">{email.subject}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    </div><!-- /panel-emails -->

    <!-- Tab: SMS -->
    <div id="panel-sms" class="hidden">
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <p class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-3">SMS</p>
        <p class="font-inter text-dark/40 text-base max-w-[400px]">Transactional and marketing SMS templates coming soon.</p>
      </div>
    </div>

    <!-- Tab: Notifications -->
    <div id="panel-notifications" class="hidden">
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <p class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-3">Notifications</p>
        <p class="font-inter text-dark/40 text-base max-w-[400px]">In-app and push notification patterns coming soon.</p>
      </div>
    </div>

    <!-- Tab: CX Journey -->
    <div id="panel-journey" class="hidden">

      <p class="font-inter text-dark/40 text-sm mb-10">Every touchpoint a WeightWise patient encounters — from first click to long-term care. Click any card to preview.</p>

      <!-- Journey phases -->
      <div class="space-y-2">

        <!-- Phase: Pre-signup -->
        <div class="journey-phase">
          <div class="flex gap-3 mb-4 items-center">
            <div class="w-2 h-2 rounded-full bg-dark/20 mt-0.5 flex-shrink-0"></div>
            <div>
              <p class="font-inter text-xs font-semibold text-dark/40 uppercase tracking-[0.12em]">Pre-Signup</p>
              <p class="font-inter text-xs text-dark/30 mt-0.5">Prospect hasn't completed registration or payment</p>
            </div>
          </div>
          <div class="ml-5 flex flex-wrap gap-2">
            {[
              { name: 'Incomplete Registration 1', slug: 'incomplete-registration-1' },
              { name: 'Incomplete Registration 2', slug: 'incomplete-registration-2' },
              { name: 'Incomplete Payment 1', slug: 'incomplete-payment-1' },
              { name: 'Incomplete Payment 2', slug: 'incomplete-payment-2' },
              { name: 'Incomplete Payment 3', slug: 'incomplete-payment-3' },
              { name: 'Recommendation Reminder 1', slug: 'recommendation-reminder-1' },
              { name: 'Recommendation Reminder 2', slug: 'recommendation-reminder-2' },
              { name: 'Recommendation Reminder 3', slug: 'recommendation-reminder-3' },
            ].map((t, i) => (
              <div class="flex items-center gap-1.5">
                <button
                  onclick={`openPreview('/emails/${t.slug}.html', '${t.name}')`}
                  class="group flex items-center gap-2.5 bg-white border border-dark/8 rounded-xl px-3.5 py-2.5 hover:border-teal/30 hover:shadow-sm transition-all text-left"
                >
                  <div class="relative w-8 h-10 rounded-md overflow-hidden bg-warm-gray/40 flex-shrink-0 pointer-events-none">
                    <iframe src={`/emails/${t.slug}.html`} class="absolute top-0 left-0 w-[600px] h-[800px] border-0 pointer-events-none" style="transform:scale(0.053);transform-origin:top left;" tabindex="-1" loading="lazy"></iframe>
                  </div>
                  <div>
                    <p class="font-inter text-dark text-xs font-semibold leading-snug group-hover:text-teal transition-colors">{t.name}</p>
                    <span class="inline-block mt-0.5 text-[10px] font-medium text-dark/30 bg-dark/5 px-1.5 py-0.5 rounded-full">Email</span>
                  </div>
                </button>
                {i < 7 && <span class="text-dark/20 text-xs">→</span>}
              </div>
            ))}
          </div>
        </div>

        <div class="ml-5 pl-px border-l-2 border-dashed border-dark/10 h-6"></div>

        <!-- Phase: Onboarding -->
        <div class="journey-phase">
          <div class="flex gap-3 mb-4 items-center">
            <div class="w-2 h-2 rounded-full bg-teal flex-shrink-0"></div>
            <div>
              <p class="font-inter text-xs font-semibold text-teal uppercase tracking-[0.12em]">Onboarding</p>
              <p class="font-inter text-xs text-dark/30 mt-0.5">Patient signs up, gets approved, and receives first shipment</p>
            </div>
          </div>
          <div class="ml-5 flex flex-wrap gap-2">
            {[
              { name: 'Email Verification', slug: 'email-verification' },
              { name: 'Welcome', slug: 'welcome' },
              { name: 'Payment Confirmed', slug: 'payment-confirmed' },
              { name: 'Prescription Confirmed', slug: 'prescription-confirmed' },
              { name: 'Treatment Shipped', slug: 'treatment-shipped' },
              { name: 'Treatment Delivered', slug: 'treatment-delivered' },
            ].map((t, i) => (
              <div class="flex items-center gap-1.5">
                <button
                  onclick={`openPreview('/emails/${t.slug}.html', '${t.name}')`}
                  class="group flex items-center gap-2.5 bg-white border border-dark/8 rounded-xl px-3.5 py-2.5 hover:border-teal/30 hover:shadow-sm transition-all text-left"
                >
                  <div class="relative w-8 h-10 rounded-md overflow-hidden bg-warm-gray/40 flex-shrink-0 pointer-events-none">
                    <iframe src={`/emails/${t.slug}.html`} class="absolute top-0 left-0 w-[600px] h-[800px] border-0 pointer-events-none" style="transform:scale(0.053);transform-origin:top left;" tabindex="-1" loading="lazy"></iframe>
                  </div>
                  <div>
                    <p class="font-inter text-dark text-xs font-semibold leading-snug group-hover:text-teal transition-colors">{t.name}</p>
                    <span class="inline-block mt-0.5 text-[10px] font-medium text-dark/30 bg-dark/5 px-1.5 py-0.5 rounded-full">Email</span>
                  </div>
                </button>
                {i < 5 && <span class="text-dark/20 text-xs">→</span>}
              </div>
            ))}
          </div>
        </div>

        <div class="ml-5 pl-px border-l-2 border-dashed border-dark/10 h-6"></div>

        <!-- Phase: Monthly Cycle -->
        <div class="journey-phase">
          <div class="flex gap-3 mb-4 items-center">
            <div class="w-2 h-2 rounded-full bg-dark flex-shrink-0"></div>
            <div class="flex items-center gap-2">
              <p class="font-inter text-xs font-semibold text-dark uppercase tracking-[0.12em]">Monthly Cycle</p>
              <span class="text-[10px] font-medium text-dark/40 bg-dark/8 px-2 py-0.5 rounded-full">Repeats each month</span>
            </div>
          </div>
          <p class="font-inter text-xs text-dark/30 mb-4 ml-5">Refill loop from heads-up through confirmation</p>
          <div class="ml-5 flex flex-wrap gap-2">
            {[
              { name: 'Refill Heads Up', slug: 'refill-heads-up' },
              { name: 'Check-in Trigger', slug: 'check-in-trigger' },
              { name: 'Reminder 1 (Gentle)', slug: 'reminder-1' },
              { name: 'Reminder 2 (Direct)', slug: 'reminder-2' },
              { name: 'Reminder 3 (Final)', slug: 'reminder-3' },
              { name: 'Refill Confirmation', slug: 'refill-confirmation' },
            ].map((t, i) => (
              <div class="flex items-center gap-1.5">
                <button
                  onclick={`openPreview('/emails/${t.slug}.html', '${t.name}')`}
                  class="group flex items-center gap-2.5 bg-white border border-dark/8 rounded-xl px-3.5 py-2.5 hover:border-teal/30 hover:shadow-sm transition-all text-left"
                >
                  <div class="relative w-8 h-10 rounded-md overflow-hidden bg-warm-gray/40 flex-shrink-0 pointer-events-none">
                    <iframe src={`/emails/${t.slug}.html`} class="absolute top-0 left-0 w-[600px] h-[800px] border-0 pointer-events-none" style="transform:scale(0.053);transform-origin:top left;" tabindex="-1" loading="lazy"></iframe>
                  </div>
                  <div>
                    <p class="font-inter text-dark text-xs font-semibold leading-snug group-hover:text-teal transition-colors">{t.name}</p>
                    <span class="inline-block mt-0.5 text-[10px] font-medium text-dark/30 bg-dark/5 px-1.5 py-0.5 rounded-full">Email</span>
                  </div>
                </button>
                {i < 5 && <span class="text-dark/20 text-xs">→</span>}
              </div>
            ))}
          </div>
        </div>

        <div class="ml-5 pl-px border-l-2 border-dashed border-dark/10 h-6"></div>

        <!-- Phase: Milestones -->
        <div class="journey-phase">
          <div class="flex gap-3 mb-4 items-center">
            <div class="w-2 h-2 rounded-full bg-teal flex-shrink-0"></div>
            <div>
              <p class="font-inter text-xs font-semibold text-teal uppercase tracking-[0.12em]">Milestones & Feedback</p>
              <p class="font-inter text-xs text-dark/30 mt-0.5">Progress recognition at key intervals</p>
            </div>
          </div>
          <div class="ml-5 flex flex-wrap gap-2">
            {[
              { name: 'Milestone — 1 Month', slug: 'milestone-1-month' },
              { name: 'Milestone — 3 Months', slug: 'milestone-3-months' },
              { name: 'Milestone — 6 Months', slug: 'milestone-6-months' },
              { name: 'NPS Survey', slug: 'nps-survey' },
            ].map((t, i) => (
              <div class="flex items-center gap-1.5">
                <button
                  onclick={`openPreview('/emails/${t.slug}.html', '${t.name}')`}
                  class="group flex items-center gap-2.5 bg-white border border-dark/8 rounded-xl px-3.5 py-2.5 hover:border-teal/30 hover:shadow-sm transition-all text-left"
                >
                  <div class="relative w-8 h-10 rounded-md overflow-hidden bg-warm-gray/40 flex-shrink-0 pointer-events-none">
                    <iframe src={`/emails/${t.slug}.html`} class="absolute top-0 left-0 w-[600px] h-[800px] border-0 pointer-events-none" style="transform:scale(0.053);transform-origin:top left;" tabindex="-1" loading="lazy"></iframe>
                  </div>
                  <div>
                    <p class="font-inter text-dark text-xs font-semibold leading-snug group-hover:text-teal transition-colors">{t.name}</p>
                    <span class="inline-block mt-0.5 text-[10px] font-medium text-dark/30 bg-dark/5 px-1.5 py-0.5 rounded-full">Email</span>
                  </div>
                </button>
                {i < 3 && <span class="text-dark/20 text-xs">→</span>}
              </div>
            ))}
          </div>
        </div>

        <div class="ml-5 pl-px border-l-2 border-dashed border-dark/10 h-6"></div>

        <!-- Phase: Billing & Account -->
        <div class="journey-phase">
          <div class="flex gap-3 mb-4 items-center">
            <div class="w-2 h-2 rounded-full bg-dark/30 flex-shrink-0"></div>
            <div>
              <p class="font-inter text-xs font-semibold text-dark/50 uppercase tracking-[0.12em]">Billing & Account</p>
              <p class="font-inter text-xs text-dark/30 mt-0.5">Triggered by payment events and plan changes</p>
            </div>
          </div>
          <div class="ml-5 flex flex-wrap gap-2">
            {[
              { name: 'Payment Received', slug: 'payment-received' },
              { name: 'Payment Failed', slug: 'payment-failed' },
              { name: 'Renewal Reminder', slug: 'renewal-reminder' },
              { name: 'Plan Change', slug: 'plan-change' },
              { name: 'Subscription Paused', slug: 'subscription-paused' },
              { name: 'Subscription Resumed', slug: 'subscription-resumed' },
              { name: 'Referral Invitation', slug: 'referral-invitation' },
              { name: 'Referral Coupon Earned', slug: 'referral-coupon-earned' },
            ].map((t, i) => (
              <div class="flex items-center gap-1.5">
                <button
                  onclick={`openPreview('/emails/${t.slug}.html', '${t.name}')`}
                  class="group flex items-center gap-2.5 bg-white border border-dark/8 rounded-xl px-3.5 py-2.5 hover:border-teal/30 hover:shadow-sm transition-all text-left"
                >
                  <div class="relative w-8 h-10 rounded-md overflow-hidden bg-warm-gray/40 flex-shrink-0 pointer-events-none">
                    <iframe src={`/emails/${t.slug}.html`} class="absolute top-0 left-0 w-[600px] h-[800px] border-0 pointer-events-none" style="transform:scale(0.053);transform-origin:top left;" tabindex="-1" loading="lazy"></iframe>
                  </div>
                  <div>
                    <p class="font-inter text-dark text-xs font-semibold leading-snug group-hover:text-teal transition-colors">{t.name}</p>
                    <span class="inline-block mt-0.5 text-[10px] font-medium text-dark/30 bg-dark/5 px-1.5 py-0.5 rounded-full">Email</span>
                  </div>
                </button>
                {i < 7 && <span class="text-dark/20 text-xs">→</span>}
              </div>
            ))}
          </div>
        </div>

        <div class="ml-5 pl-px border-l-2 border-dashed border-dark/10 h-6"></div>

        <!-- Phase: Clinical -->
        <div class="journey-phase">
          <div class="flex gap-3 mb-4 items-center">
            <div class="w-2 h-2 rounded-full bg-dark/30 flex-shrink-0"></div>
            <div>
              <p class="font-inter text-xs font-semibold text-dark/50 uppercase tracking-[0.12em]">Clinical Events</p>
              <p class="font-inter text-xs text-dark/30 mt-0.5">Triggered by provider decisions and health flags</p>
            </div>
          </div>
          <div class="ml-5 flex flex-wrap gap-2">
            {[
              { name: 'Prescription Denied', slug: 'prescription-denied' },
              { name: 'Medication Switch Result', slug: 'medication-switch-result' },
              { name: 'Dose Change Confirmation', slug: 'dose-change-confirmation' },
              { name: 'Red Flag Escalation', slug: 'red-flag-escalation' },
            ].map((t, i) => (
              <div class="flex items-center gap-1.5">
                <button
                  onclick={`openPreview('/emails/${t.slug}.html', '${t.name}')`}
                  class="group flex items-center gap-2.5 bg-white border border-dark/8 rounded-xl px-3.5 py-2.5 hover:border-teal/30 hover:shadow-sm transition-all text-left"
                >
                  <div class="relative w-8 h-10 rounded-md overflow-hidden bg-warm-gray/40 flex-shrink-0 pointer-events-none">
                    <iframe src={`/emails/${t.slug}.html`} class="absolute top-0 left-0 w-[600px] h-[800px] border-0 pointer-events-none" style="transform:scale(0.053);transform-origin:top left;" tabindex="-1" loading="lazy"></iframe>
                  </div>
                  <div>
                    <p class="font-inter text-dark text-xs font-semibold leading-snug group-hover:text-teal transition-colors">{t.name}</p>
                    <span class="inline-block mt-0.5 text-[10px] font-medium text-dark/30 bg-dark/5 px-1.5 py-0.5 rounded-full">Email</span>
                  </div>
                </button>
                {i < 3 && <span class="text-dark/20 text-xs">→</span>}
              </div>
            ))}
          </div>
        </div>

        <div class="ml-5 pl-px border-l-2 border-dashed border-dark/10 h-6"></div>

        <!-- Phase: Winback -->
        <div class="journey-phase">
          <div class="flex gap-3 mb-4 items-center">
            <div class="w-2 h-2 rounded-full bg-terracotta flex-shrink-0"></div>
            <div>
              <p class="font-inter text-xs font-semibold text-terracotta uppercase tracking-[0.12em]">Winback</p>
              <p class="font-inter text-xs text-dark/30 mt-0.5">Post-cancellation re-engagement sequence</p>
            </div>
          </div>
          <div class="ml-5 flex flex-wrap gap-2">
            {[
              { name: 'Cancellation Confirmation', slug: 'cancellation-confirmation' },
              { name: 'Winback — Day 14', slug: 'winback-day-14' },
              { name: 'Winback — Day 30', slug: 'winback-day-30' },
              { name: 'Winback — Day 60', slug: 'winback-day-60' },
            ].map((t, i) => (
              <div class="flex items-center gap-1.5">
                <button
                  onclick={`openPreview('/emails/${t.slug}.html', '${t.name}')`}
                  class="group flex items-center gap-2.5 bg-white border border-dark/8 rounded-xl px-3.5 py-2.5 hover:border-teal/30 hover:shadow-sm transition-all text-left"
                >
                  <div class="relative w-8 h-10 rounded-md overflow-hidden bg-warm-gray/40 flex-shrink-0 pointer-events-none">
                    <iframe src={`/emails/${t.slug}.html`} class="absolute top-0 left-0 w-[600px] h-[800px] border-0 pointer-events-none" style="transform:scale(0.053);transform-origin:top left;" tabindex="-1" loading="lazy"></iframe>
                  </div>
                  <div>
                    <p class="font-inter text-dark text-xs font-semibold leading-snug group-hover:text-teal transition-colors">{t.name}</p>
                    <span class="inline-block mt-0.5 text-[10px] font-medium text-terracotta/60 bg-terracotta/8 px-1.5 py-0.5 rounded-full">Email</span>
                  </div>
                </button>
                {i < 3 && <span class="text-dark/20 text-xs">→</span>}
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- Fullscreen Preview Overlay -->
  <div id="overlay" class="fixed inset-0 bg-dark/70 z-[100] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="fullscreen-frame bg-white rounded-2xl overflow-hidden w-[90vw] max-w-[700px] h-[85vh] flex flex-col shadow-2xl">
      <!-- Control bar -->
      <div class="flex items-center justify-between px-5 py-3 border-b border-dark/8 bg-warm-gray/30">
        <span id="preview-name" class="font-inter text-dark text-sm font-semibold"></span>
        <div class="flex items-center gap-3">
          <button id="toggle-btn" onclick="toggleMobile()" class="px-4 py-1.5 rounded-full bg-teal text-white text-xs font-medium hover:bg-teal/90 transition-colors">
            Mobile view
          </button>
          <button onclick="closePreview()" class="text-dark/30 hover:text-dark transition-colors text-lg leading-none">&times;</button>
        </div>
      </div>
      <!-- Preview iframe -->
      <div class="flex-1 overflow-auto bg-warm-gray/20 flex justify-center p-4">
        <iframe id="preview-iframe" class="w-full h-full border-0 bg-white rounded-lg shadow-sm" style="max-width:100%;"></iframe>
      </div>
    </div>
  </div>

  <!-- Mobile toggle FAB -->
  <button id="fab-toggle" class="fixed bottom-6 right-6 z-[90] px-5 py-3 rounded-full bg-teal text-white text-xs font-semibold shadow-lg hover:shadow-xl hover:scale-105 transition-all hidden" onclick="toggleMobile()">
    Mobile view
  </button>

  <script is:inline>
    const tabs = ['emails', 'sms', 'notifications', 'journey'];
    const products = ['weightwise', 'nimcore'];

    function switchProduct(active) {
      products.forEach(p => {
        const btn = document.getElementById('prod-' + p);
        btn.className = p === active
          ? 'px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark text-cream'
          : 'px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark';
      });
    }

    function switchTab(active) {
      tabs.forEach(t => {
        const panel = document.getElementById('panel-' + t);
        const btn = document.getElementById('tab-' + t);
        if (t === active) {
          panel.classList.remove('hidden');
          btn.className = 'px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark text-cream';
        } else {
          panel.classList.add('hidden');
          btn.className = 'px-5 py-2 rounded-full text-sm font-medium transition-all bg-dark/8 text-dark/50 hover:bg-dark/12 hover:text-dark';
        }
      });
    }

    // Set defaults on load
    switchTab('emails');

    let isMobile = false;

    function openPreview(src, name) {
      document.getElementById('preview-name').textContent = name;
      document.getElementById('preview-iframe').src = src;
      const overlay = document.getElementById('overlay');
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      document.body.style.overflow = 'hidden';
      isMobile = false;
      updateFrame();
    }

    function closePreview(e) {
      if (e && e.target && e.target !== document.getElementById('overlay')) return;
      const overlay = document.getElementById('overlay');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      document.getElementById('preview-iframe').src = '';
      document.body.style.overflow = '';
    }

    function toggleMobile() {
      isMobile = !isMobile;
      updateFrame();
    }

    function updateFrame() {
      const frame = document.querySelector('.fullscreen-frame');
      const btn = document.getElementById('toggle-btn');
      const fab = document.getElementById('fab-toggle');
      if (isMobile) {
        frame.style.maxWidth = '375px';
        btn.textContent = 'Desktop view';
        if (fab) fab.textContent = 'Desktop view';
      } else {
        frame.style.maxWidth = '700px';
        btn.textContent = 'Mobile view';
        if (fab) fab.textContent = 'Mobile view';
      }
    }

    // Close on overlay background click
    document.getElementById('overlay').addEventListener('click', function(e) {
      if (e.target === this) closePreview();
    });

    // Close on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closePreview();
    });

    // Card click handlers — load email HTML in preview
    document.querySelectorAll('.email-card').forEach(function(card) {
      card.addEventListener('click', function() {
        const name = this.dataset.name;
        const slug = this.dataset.slug;
        openPreview('/emails/' + slug + '.html', name);
      });
    });
  </script>
</Layout>
