---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marketing" active="marketing">
  <div class="max-w-[900px] mx-auto px-10 py-16">
    <!-- Page Header -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-[2px] bg-teal"></div>
        <span class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase">Marketing</span>
        <div class="w-10 h-[2px] bg-teal"></div>
      </div>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Marketing
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        Marketing guidelines, campaign assets, messaging frameworks, and channel-specific rules for Nimbus Healthcare.
      </p>
    </div>
  </div>
</Layout>
