---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Intakes" active="intakes" sections={[
  { label: 'Intakes', id: 'live' },
  { label: 'Flow', id: 'flow' },
  { label: 'Progress Bar', id: 'progress' },
  { label: 'Programs', id: 'programs' },
  { label: 'Pricing', id: 'pricing' },
  { label: 'Form Elements', id: 'forms' },
  { label: 'Health Screening', id: 'screening' },
  { label: 'Photo Upload', id: 'photos' },
  { label: 'Checkout', id: 'checkout' },
  { label: 'Price Change', id: 'price-change' },
  { label: 'Layout', id: 'layout' },
]}>
  <div class="max-w-[900px] mx-auto px-10 py-16">
    <!-- Page Header -->
    <div class="mb-16">
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Intakes
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        Design patterns for patient onboarding, intake forms, program selection, pricing, and the checkout experience.
      </p>
    </div>

    <!-- Live Pages -->
    <section id="live" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Intakes</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Patient Intake -->
        <a href="https://nimbus-26.vercel.app/intake" target="_blank" rel="noopener noreferrer" class="group block bg-dark rounded-3xl overflow-hidden hover:translate-y-[-4px] hover:shadow-xl transition-all duration-350">
          <div class="relative aspect-[16/10] overflow-hidden">
            <img src="/images/Portal/intake-hand.png" alt="Patient Intake" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
          </div>
          <div class="px-6 py-4 flex items-center justify-between border-t border-cream/5">
            <span class="font-mono text-white text-xs">/intake</span>
            <span class="font-inter text-white text-sm group-hover:translate-x-1 transition-transform">View &rarr;</span>
          </div>
        </a>

        <!-- Price Change -->
        <a href="https://nimbus-26.vercel.app/price-change" target="_blank" rel="noopener noreferrer" class="group block bg-dark rounded-3xl overflow-hidden hover:translate-y-[-4px] hover:shadow-xl transition-all duration-350">
          <div class="relative aspect-[16/10] overflow-hidden">
            <img src="/images/NB_Vial6.png" alt="Price Change" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
          </div>
          <div class="px-6 py-4 flex items-center justify-between border-t border-cream/5">
            <span class="font-mono text-white text-xs">/price-change</span>
            <span class="font-inter text-white text-sm group-hover:translate-x-1 transition-transform">View &rarr;</span>
          </div>
        </a>
      </div>
    </section>

    <!-- Intake Flow Overview -->
    <section id="flow" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Intake Flow</h2>

      <div class="bg-warm-gray rounded-3xl p-8 mb-6">
        <h3 class="font-inter text-sm font-semibold mb-2">Flow Structure</h3>
        <p class="font-inter text-dark/60 text-sm leading-[1.6] mb-6">
          The intake is an 18-step wizard that guides patients from state eligibility through payment and onboarding. Each step is a single focused question or group of related inputs.
        </p>
        <div class="flex flex-wrap gap-2">
          {[
            'State Selection',
            'Date of Birth & Sex',
            'Height & Weight',
            'Health Goals',
            'GLP-1 Experience',
            'Account Setup',
            'Plan & Pricing',
            'Checkout',
            'Safety Screening',
            'Comorbidities',
            'Founder Intro',
            'Current Medications',
            'Medication Allergies',
            'Government ID',
            'Body Photo',
            'Shipping Address',
            'Order Confirmation',
            'Summary',
          ].map((step, i) => (
            <div class="bg-cream rounded-full px-4 py-2 font-inter text-xs font-medium text-dark/60">
              <span class="text-teal font-semibold mr-1">{i + 1}</span> {step}
            </div>
          ))}
        </div>
      </div>

      <div class="bg-warm-gray rounded-3xl p-8">
        <h3 class="font-inter text-sm font-semibold mb-4">Nimy — AI Health Coach Intro</h3>
        <p class="font-inter text-dark/60 text-sm leading-[1.6]">
          The flow opens with Nimy, a virtual health coach persona, to set a warm, guided tone before clinical questions begin. Messaging: <span class="italic">"Hi, I'm Nimy — your health coach from Nimbus Healthcare."</span> IntelliHealth™ clinical review is disclosed at this step.
        </p>
      </div>
    </section>

    <!-- Progress Bar -->
    <section id="progress" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Progress Bar</h2>

      <div class="bg-dark rounded-3xl p-8 mb-6">
        <div class="flex items-center justify-between mb-3">
          <span class="font-inter text-cream/40 text-xs">Step 3 of 18</span>
          <span class="font-inter text-cream/40 text-xs">17%</span>
        </div>
        <div class="w-full h-1 bg-cream/10 rounded-full overflow-hidden mb-8">
          <div class="h-full bg-teal rounded-full" style="width: 17%"></div>
        </div>
        <div class="flex items-center justify-between mb-3">
          <span class="font-inter text-cream/40 text-xs">Step 11 of 18</span>
          <span class="font-inter text-cream/40 text-xs">61%</span>
        </div>
        <div class="w-full h-1 bg-cream/10 rounded-full overflow-hidden">
          <div class="h-full bg-teal rounded-full" style="width: 61%"></div>
        </div>
        <p class="font-inter text-cream/30 text-xs mt-6">Teal fill on cream/10 track · 4px height · rounded-full · percentage shown top-right</p>
      </div>

      <div class="bg-warm-gray rounded-3xl p-8">
        <h3 class="font-inter text-sm font-semibold mb-4">Rules</h3>
        <ul class="space-y-2 font-inter text-sm text-dark/60">
          <li>Fixed at top of the intake viewport</li>
          <li>Teal fill (<code class="bg-dark/5 px-1.5 py-0.5 rounded text-xs">#2A9D8F</code>) on <code class="bg-dark/5 px-1.5 py-0.5 rounded text-xs">cream/10</code> track</li>
          <li>Smooth transition on step change (<code class="bg-dark/5 px-1.5 py-0.5 rounded text-xs">transition: width 500ms ease-out</code>)</li>
          <li>Percentage reflects current step / total steps · Step counter shown alongside</li>
          <li>Back button with phase label visible in top-left</li>
        </ul>
      </div>
    </section>

    <!-- Programs -->
    <section id="programs" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Programs</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
        <!-- CarniSema -->
        <div class="bg-dark rounded-3xl p-7">
          <div class="mb-4">
            <p class="font-inter text-cream/40 text-xs font-medium uppercase tracking-widest mb-1">Semaglutide</p>
            <h3 class="font-fraunces text-cream text-2xl tracking-tight">CarniSema<sup class="text-sm">®</sup></h3>
          </div>
          <p class="font-inter text-cream/60 text-sm leading-[1.6] mb-5">
            Semaglutide + L-Carnitine. GLP-1 receptor agonist that reduces appetite and supports fat metabolism.
          </p>
          <div class="border-t border-cream/10 pt-4 space-y-2">
            <div class="flex justify-between font-inter text-sm">
              <span class="text-cream/50">Month-to-Month</span>
              <span class="text-cream font-medium">$179/mo</span>
            </div>
            <div class="flex justify-between font-inter text-sm">
              <span class="text-cream/50">3-Month Journey</span>
              <span class="text-cream font-medium">$149/mo</span>
            </div>
            <div class="flex justify-between font-inter text-sm">
              <span class="text-cream/50">6-Month Transformation</span>
              <span class="text-cream font-medium">$129/mo</span>
            </div>
          </div>
        </div>

        <!-- CarniTide -->
        <div class="bg-dark rounded-3xl p-7">
          <div class="mb-4">
            <p class="font-inter text-cream/40 text-xs font-medium uppercase tracking-widest mb-1">Tirzepatide</p>
            <h3 class="font-fraunces text-cream text-2xl tracking-tight">CarniTide<sup class="text-sm">®</sup></h3>
          </div>
          <p class="font-inter text-cream/60 text-sm leading-[1.6] mb-5">
            Tirzepatide + L-Carnitine. Dual-action GLP-1/GIP agonist for enhanced weight loss and metabolic support.
          </p>
          <div class="border-t border-cream/10 pt-4 space-y-2">
            <div class="flex justify-between font-inter text-sm">
              <span class="text-cream/50">Month-to-Month</span>
              <span class="text-cream font-medium">$299/mo</span>
            </div>
            <div class="flex justify-between font-inter text-sm">
              <span class="text-cream/50">3-Month Journey</span>
              <span class="text-cream font-medium">$249/mo</span>
            </div>
            <div class="flex justify-between font-inter text-sm">
              <span class="text-cream/50">6-Month Transformation</span>
              <span class="text-cream font-medium">$219/mo</span>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-warm-gray rounded-3xl p-8">
        <h3 class="font-inter text-sm font-semibold mb-3">Program Card Rules</h3>
        <ul class="space-y-2 font-inter text-sm text-dark/60">
          <li>Medication type label: Inter, 11px, uppercase, wide tracking, cream/40</li>
          <li>Product name: Fraunces 24px, cream — registered mark as superscript</li>
          <li>Description: Inter 14px, cream/60, 1.6 line height</li>
          <li>Pricing rows separated by a cream/10 top border</li>
          <li>Selected state: border-2 teal/30, bg teal/5 ring around card</li>
        </ul>
      </div>
    </section>

    <!-- Pricing Tables -->
    <section id="pricing" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Pricing Tables</h2>

      <div class="space-y-8 mb-6">
        <!-- CarniSema Pricing Table -->
        <div class="bg-dark rounded-3xl overflow-hidden">
          <div class="px-8 pt-7 pb-5">
            <h3 class="font-fraunces text-cream text-xl tracking-tight">
              CarniSema<sup class="text-sm">®</sup> <span class="font-inter font-normal text-cream/50 text-base">Pricing (Semaglutide)</span>
            </h3>
          </div>
          <table class="w-full">
            <thead>
              <tr class="border-t border-b border-cream/10">
                <th class="px-8 py-4 text-left font-inter text-sm font-semibold text-cream">Commitment</th>
                <th class="px-8 py-4 text-left font-inter text-sm font-semibold text-cream">Monthly Price</th>
                <th class="px-8 py-4 text-left font-inter text-sm font-semibold text-cream">Savings</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-cream/5">
                <td class="px-8 py-4 font-inter text-sm text-cream/70">Month-to-Month</td>
                <td class="px-8 py-4 font-inter text-sm font-semibold text-cream">$179/mo</td>
                <td class="px-8 py-4 font-inter text-sm text-cream/40">—</td>
              </tr>
              <tr class="border-b border-cream/5">
                <td class="px-8 py-4 font-inter text-sm text-cream/70">3-Month Journey</td>
                <td class="px-8 py-4 font-inter text-sm font-semibold text-cream">$149/mo</td>
                <td class="px-8 py-4 font-inter text-sm text-teal font-medium">Save 17%</td>
              </tr>
              <tr>
                <td class="px-8 py-4 font-inter text-sm text-cream/70">6-Month Transformation</td>
                <td class="px-8 py-4 font-inter text-sm font-semibold text-cream">$129/mo</td>
                <td class="px-8 py-4 font-inter text-sm text-teal font-medium">Save 28%</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- CarniTide Pricing Table -->
        <div class="bg-dark rounded-3xl overflow-hidden">
          <div class="px-8 pt-7 pb-5">
            <h3 class="font-fraunces text-cream text-xl tracking-tight">
              CarniTide<sup class="text-sm">®</sup> <span class="font-inter font-normal text-cream/50 text-base">Pricing (Tirzepatide)</span>
            </h3>
          </div>
          <table class="w-full">
            <thead>
              <tr class="border-t border-b border-cream/10">
                <th class="px-8 py-4 text-left font-inter text-sm font-semibold text-cream">Commitment</th>
                <th class="px-8 py-4 text-left font-inter text-sm font-semibold text-cream">Monthly Price</th>
                <th class="px-8 py-4 text-left font-inter text-sm font-semibold text-cream">Savings</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-cream/5">
                <td class="px-8 py-4 font-inter text-sm text-cream/70">Month-to-Month</td>
                <td class="px-8 py-4 font-inter text-sm font-semibold text-cream">$299/mo</td>
                <td class="px-8 py-4 font-inter text-sm text-cream/40">—</td>
              </tr>
              <tr class="border-b border-cream/5">
                <td class="px-8 py-4 font-inter text-sm text-cream/70">3-Month Journey</td>
                <td class="px-8 py-4 font-inter text-sm font-semibold text-cream">$249/mo</td>
                <td class="px-8 py-4 font-inter text-sm text-teal font-medium">Save 17%</td>
              </tr>
              <tr>
                <td class="px-8 py-4 font-inter text-sm text-cream/70">6-Month Transformation</td>
                <td class="px-8 py-4 font-inter text-sm font-semibold text-cream">$219/mo</td>
                <td class="px-8 py-4 font-inter text-sm text-teal font-medium">Save 27%</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Commitment Toggle -->
      <div class="bg-dark rounded-3xl p-8 mb-6">
        <h3 class="font-inter text-cream text-sm font-semibold mb-5">Commitment Toggle</h3>
        <div class="inline-flex bg-cream/5 rounded-full p-1 gap-1 mb-5">
          <button class="px-5 py-2 rounded-full bg-cream text-dark font-inter text-sm font-medium">Monthly</button>
          <button class="px-5 py-2 rounded-full font-inter text-sm font-medium text-cream/50">3-Month</button>
          <button class="px-5 py-2 rounded-full font-inter text-sm font-medium text-cream/50">6-Month</button>
        </div>
        <p class="font-inter text-cream/30 text-xs">Pill toggle switches active pricing column · Active tab: cream bg, dark text · Inactive: cream/50</p>
      </div>

      <div class="bg-warm-gray rounded-3xl p-8">
        <h3 class="font-inter text-sm font-semibold mb-4">Pricing Table Rules</h3>
        <ul class="space-y-2 font-inter text-sm text-dark/60">
          <li>Product title: Fraunces 20px cream · subtitle: Inter normal cream/50</li>
          <li>Table headers: Inter 14px semibold cream · rows separated by cream/5 border</li>
          <li>Price column: Inter semibold cream · Savings column: teal for discounted, cream/40 dash for baseline</li>
          <li>Plan names: "Month-to-Month", "3-Month Journey", "6-Month Transformation"</li>
          <li>Toggle pill: cream/5 bg container · active state cream bg, dark text</li>
        </ul>
      </div>
    </section>

    <!-- Form Elements -->
    <section id="forms" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Form Elements</h2>

      <div class="space-y-6">
        <!-- Text Input -->
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-5">Text Input</h3>
          <div class="max-w-[400px] space-y-4">
            <div>
              <label class="block font-inter text-cream/60 text-sm mb-2">Full Name</label>
              <input type="text" placeholder="Enter your full name" class="w-full bg-cream/5 border border-cream/10 rounded-xl px-4 py-3.5 font-inter text-cream text-sm placeholder:text-cream/30 focus:outline-none focus:border-teal/50 transition-colors" />
            </div>
            <div>
              <label class="block font-inter text-cream/60 text-sm mb-2">Email Address</label>
              <input type="email" placeholder="you@example.com" class="w-full bg-cream/5 border border-cream/10 rounded-xl px-4 py-3.5 font-inter text-cream text-sm placeholder:text-cream/30 focus:outline-none focus:border-teal/50 transition-colors" />
            </div>
          </div>
          <div class="mt-5 font-inter text-cream/30 text-xs space-y-1">
            <p>Background: cream/5 · Border: cream/10 · Focus border: teal/50</p>
            <p>Radius: 12px (rounded-xl) · Padding: 14px 16px · Font: Inter 14px</p>
            <p>Date of birth input auto-formats as MM/DD/YYYY</p>
          </div>
        </div>

        <!-- Selection Cards -->
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-5">Selection Cards (Single-Select)</h3>
          <div class="grid grid-cols-2 gap-3 max-w-[400px] mb-6">
            <button class="border-2 border-teal/30 bg-teal/5 rounded-2xl p-4 text-left">
              <p class="font-inter text-cream text-sm font-medium">Male</p>
            </button>
            <button class="border border-cream/10 hover:border-cream/20 rounded-2xl p-4 text-left transition-colors">
              <p class="font-inter text-cream/60 text-sm font-medium">Female</p>
            </button>
          </div>
          <h3 class="font-inter text-cream text-sm font-semibold mb-3">Multi-Select Cards (Goals / Comorbidities)</h3>
          <div class="grid grid-cols-2 gap-3 max-w-[400px]">
            <button class="border-2 border-teal/30 bg-teal/5 rounded-2xl p-4 text-left">
              <p class="font-inter text-cream text-sm font-medium">Lose Weight</p>
              <p class="font-inter text-cream/40 text-xs mt-0.5">Selected</p>
            </button>
            <button class="border-2 border-teal/30 bg-teal/5 rounded-2xl p-4 text-left">
              <p class="font-inter text-cream text-sm font-medium">More Energy</p>
              <p class="font-inter text-cream/40 text-xs mt-0.5">Selected</p>
            </button>
            <button class="border border-cream/10 hover:border-cream/20 rounded-2xl p-4 text-left transition-colors">
              <p class="font-inter text-cream/60 text-sm font-medium">Better Sleep</p>
            </button>
            <button class="border border-cream/10 hover:border-cream/20 rounded-2xl p-4 text-left transition-colors">
              <p class="font-inter text-cream/60 text-sm font-medium">Reduce Meds</p>
            </button>
          </div>
          <div class="mt-5 font-inter text-cream/30 text-xs space-y-1">
            <p>Selected: border-2 teal/30, bg teal/5, full-opacity text</p>
            <p>Unselected: border cream/10, hover cream/20, text cream/60</p>
            <p>Multi-select allows multiple active states simultaneously</p>
            <p>Radius: 16px (rounded-2xl)</p>
          </div>
        </div>

        <!-- State Selection -->
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-5">State Selection</h3>
          <div class="flex flex-wrap gap-2 max-w-[500px]">
            {['AL', 'AK', 'AZ', 'AR', 'CA', 'CO', 'CT', 'DE', 'FL', 'GA', 'HI', 'ID', 'IL', 'IN', 'IA', 'KS', 'KY', 'LA', 'ME', 'MD'].map(state => (
              <button class={`px-3 py-2 rounded-xl font-inter text-xs font-medium border transition-colors ${state === 'TX' ? 'border-2 border-teal/30 bg-teal/5 text-cream' : 'border-cream/10 text-cream/50 hover:border-cream/20'}`}>
                {state}
              </button>
            ))}
            <span class="font-inter text-cream/30 text-xs self-center ml-1">… all 50 states</span>
          </div>
          <p class="font-inter text-cream/30 text-xs mt-5">Abbreviation pills · Selected: teal/30 border, teal/5 bg · Unselected: cream/10 border · Radius: 12px</p>
        </div>

        <!-- Stepper Inputs -->
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-5">Stepper Inputs (Height & Weight)</h3>
          <div class="flex gap-6 max-w-[400px]">
            <div class="flex-1">
              <label class="block font-inter text-cream/60 text-xs mb-3">Feet</label>
              <div class="flex items-center gap-3">
                <button class="w-10 h-10 rounded-full border border-cream/20 text-cream font-inter text-lg flex items-center justify-center hover:border-cream/40 transition-colors">−</button>
                <span class="font-fraunces text-cream text-3xl w-8 text-center">5</span>
                <button class="w-10 h-10 rounded-full border border-cream/20 text-cream font-inter text-lg flex items-center justify-center hover:border-cream/40 transition-colors">+</button>
              </div>
            </div>
            <div class="flex-1">
              <label class="block font-inter text-cream/60 text-xs mb-3">Inches</label>
              <div class="flex items-center gap-3">
                <button class="w-10 h-10 rounded-full border border-cream/20 text-cream font-inter text-lg flex items-center justify-center hover:border-cream/40 transition-colors">−</button>
                <span class="font-fraunces text-cream text-3xl w-8 text-center">8</span>
                <button class="w-10 h-10 rounded-full border border-cream/20 text-cream font-inter text-lg flex items-center justify-center hover:border-cream/40 transition-colors">+</button>
              </div>
            </div>
            <div class="flex-1">
              <label class="block font-inter text-cream/60 text-xs mb-3">lbs</label>
              <div class="flex items-center gap-3">
                <button class="w-10 h-10 rounded-full border border-cream/20 text-cream font-inter text-lg flex items-center justify-center hover:border-cream/40 transition-colors">−</button>
                <span class="font-fraunces text-cream text-3xl w-10 text-center">185</span>
                <button class="w-10 h-10 rounded-full border border-cream/20 text-cream font-inter text-lg flex items-center justify-center hover:border-cream/40 transition-colors">+</button>
              </div>
            </div>
          </div>
          <div class="mt-5 font-inter text-cream/30 text-xs space-y-1">
            <p>+/− buttons: 40px circle, border cream/20, hover cream/40</p>
            <p>Value: Fraunces 30px cream · Label: Inter 12px cream/60</p>
            <p>Separate steppers for feet, inches, and lbs</p>
          </div>
        </div>

        <!-- Medication Search -->
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-5">Medication Search</h3>
          <div class="max-w-[420px]">
            <input type="text" placeholder="Search medications…" class="w-full bg-cream/5 border border-cream/10 rounded-xl px-4 py-3.5 font-inter text-cream text-sm placeholder:text-cream/30 focus:outline-none focus:border-teal/50 transition-colors mb-4" />
            <div class="space-y-2">
              {['Blood Pressure', 'Thyroid', 'Diabetes', 'Mental Health', 'Cholesterol', 'Vitamins & Supplements'].map(cat => (
