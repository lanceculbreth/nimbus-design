---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Intakes" active="intakes">
  <div class="max-w-[900px] mx-auto px-10 py-16">
    <!-- Page Header -->
    <div class="mb-16">
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Intakes
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        Design patterns for patient onboarding, intake forms, and the checkout experience.
      </p>
    </div>

    <!-- Live Pages -->
    <section id="live" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Intakes</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Patient Intake -->
        <a href="https://nimbus-26.vercel.app/intake" target="_blank" rel="noopener noreferrer" class="group block bg-dark rounded-3xl overflow-hidden hover:translate-y-[-4px] hover:shadow-xl transition-all duration-350">
          <div class="relative aspect-[16/10] overflow-hidden">
            <img src="/images/intake-hand.png" alt="Patient Intake" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
          </div>
          <div class="px-6 py-4 flex items-center justify-between border-t border-cream/5">
            <span class="font-mono text-white text-xs">/intake</span>
            <span class="font-inter text-white text-sm group-hover:translate-x-1 transition-transform">View &rarr;</span>
          </div>
        </a>

        <!-- Price Change -->
        <a href="https://nimbus-26.vercel.app/price-change" target="_blank" rel="noopener noreferrer" class="group block bg-dark rounded-3xl overflow-hidden hover:translate-y-[-4px] hover:shadow-xl transition-all duration-350">
          <div class="relative aspect-[16/10] overflow-hidden">
            <img src="/images/NB_Vial6.png" alt="Price Change" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
          </div>
          <div class="px-6 py-4 flex items-center justify-between border-t border-cream/5">
            <span class="font-mono text-white text-xs">/price-change</span>
            <span class="font-inter text-white text-sm group-hover:translate-x-1 transition-transform">View &rarr;</span>
          </div>
        </a>
      </div>
    </section>

    <!-- Intake Flow Overview -->
    <section id="flow" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Intake Flow</h2>

      <div class="bg-warm-gray rounded-3xl p-8 mb-8">
        <h3 class="font-inter text-sm font-semibold mb-4">Flow Structure</h3>
        <p class="font-inter text-dark/60 text-sm leading-[1.6] mb-4">
          The intake is a multi-step wizard that guides patients from program selection through payment. Each step is a single focused question or group.
        </p>
        <div class="flex flex-wrap gap-2">
          {['Program Select', 'Personal Info', 'Health History', 'Medications', 'Allergies', 'Goals', 'Lab Selection', 'Photo Upload', 'Provider Review', 'Checkout'].map((step, i) => (
            <div class="bg-cream rounded-full px-4 py-2 font-inter text-xs font-medium text-dark/60">
              <span class="text-teal font-semibold mr-1">{i + 1}</span> {step}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Progress Bar -->
    <section id="progress" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Progress Bar</h2>

      <div class="bg-dark rounded-3xl p-8 mb-6">
        <div class="mb-6">
          <div class="w-full h-1 bg-cream/10 rounded-full overflow-hidden">
            <div class="h-full bg-teal rounded-full" style="width: 35%"></div>
          </div>
        </div>
        <p class="font-inter text-cream/40 text-xs">Teal fill on cream/10 track. Full width, 4px height, rounded-full.</p>
      </div>

      <div class="bg-warm-gray rounded-3xl p-8">
        <h3 class="font-inter text-sm font-semibold mb-4">Rules</h3>
        <ul class="space-y-2 font-inter text-sm text-dark/60">
          <li>Fixed at top of the intake viewport</li>
          <li>Teal fill (<code class="bg-dark/5 px-1.5 py-0.5 rounded text-xs">#2A9D8F</code>) on <code class="bg-dark/5 px-1.5 py-0.5 rounded text-xs">cream/10</code> track</li>
          <li>Smooth transition on step change (<code class="bg-dark/5 px-1.5 py-0.5 rounded text-xs">transition: width 500ms ease-out</code>)</li>
          <li>Percentage reflects current step / total steps</li>
        </ul>
      </div>
    </section>

    <!-- Form Elements -->
    <section id="forms" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Form Elements</h2>

      <div class="space-y-6">
        <!-- Text Input -->
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-4">Text Input</h3>
          <div class="max-w-[400px]">
            <label class="block font-inter text-cream/60 text-sm mb-2">Full Name</label>
            <input type="text" placeholder="Enter your full name" class="w-full bg-cream/5 border border-cream/10 rounded-xl px-4 py-3.5 font-inter text-cream text-sm placeholder:text-cream/30 focus:outline-none focus:border-teal/50 transition-colors" />
          </div>
          <div class="mt-4 font-inter text-cream/30 text-xs space-y-1">
            <p>Background: cream/5 &middot; Border: cream/10 &middot; Focus border: teal/50</p>
            <p>Radius: 12px (rounded-xl) &middot; Padding: 14px 16px &middot; Font: Inter 14px</p>
          </div>
        </div>

        <!-- Selection Cards -->
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-4">Selection Cards</h3>
          <div class="grid grid-cols-2 gap-3 max-w-[400px]">
            <button class="border-2 border-teal/30 bg-teal/5 rounded-2xl p-4 text-left">
              <p class="font-inter text-cream text-sm font-medium">Male</p>
            </button>
            <button class="border border-cream/10 hover:border-cream/20 rounded-2xl p-4 text-left transition-colors">
              <p class="font-inter text-cream/60 text-sm font-medium">Female</p>
            </button>
          </div>
          <div class="mt-4 font-inter text-cream/30 text-xs space-y-1">
            <p>Selected: border-2 teal/30, bg teal/5</p>
            <p>Unselected: border cream/10, hover cream/20</p>
            <p>Radius: 16px (rounded-2xl)</p>
          </div>
        </div>

        <!-- Continue Button -->
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-4">Continue Button</h3>
          <div class="max-w-[400px]">
            <button class="w-full bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-colors">
              Continue
            </button>
          </div>
          <div class="mt-4 font-inter text-cream/30 text-xs space-y-1">
            <p>Full width within form container</p>
            <p>Terracotta bg &rarr; Terracotta Hover on hover</p>
            <p>Montserrat medium 16px &middot; Rounded full &middot; Padding: 16px 40px</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Checkout -->
    <section id="checkout" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Checkout</h2>
      <div class="bg-warm-gray rounded-3xl p-8">
        <h3 class="font-inter text-sm font-semibold mb-4">Checkout Rules</h3>
        <ul class="space-y-2 font-inter text-sm text-dark/60">
          <li>Embedded within the intake flow (not a separate page redirect)</li>
          <li>Order summary visible alongside payment form</li>
          <li>Submit button uses primary CTA pattern (terracotta, full-width)</li>
          <li>Trust indicators: SSL badge, pharmacy accreditation, refund policy link</li>
          <li>Disclaimer text at bottom: cream/30, 12px Inter</li>
        </ul>
      </div>
    </section>

    <!-- Layout Pattern -->
    <section id="layout">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Intake Layout</h2>
      <div class="space-y-6">
        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-4">Desktop: Split Layout</h3>
          <div class="grid grid-cols-2 gap-4 min-h-[200px]">
            <div class="bg-cream/5 rounded-2xl flex items-center justify-center">
              <span class="font-inter text-cream/30 text-sm">Video / Image</span>
            </div>
            <div class="bg-charcoal rounded-2xl flex items-center justify-center">
              <span class="font-inter text-cream/30 text-sm">Form Content</span>
            </div>
          </div>
          <p class="font-inter text-cream/30 text-xs mt-4">Desktop uses a 50/50 split. Left: hero media. Right: form on charcoal (#22201E).</p>
        </div>

        <div class="bg-dark rounded-3xl p-8">
          <h3 class="font-inter text-cream text-sm font-semibold mb-4">Mobile: Stacked</h3>
          <div class="max-w-[200px] mx-auto space-y-3">
            <div class="bg-charcoal rounded-2xl h-[200px] flex items-center justify-center">
              <span class="font-inter text-cream/30 text-xs">Form Content</span>
            </div>
          </div>
          <p class="font-inter text-cream/30 text-xs mt-4 text-center">Mobile hides the media panel. Full-width form on dark background.</p>
        </div>
      </div>
    </section>
  </div>
</Layout>
