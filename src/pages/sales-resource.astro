---
import Layout from '../layouts/Layout.astro';

const states = [
  'Alabama', 'Arizona', 'Arkansas', 'Colorado', 'Florida', 'Georgia',
  'Hawaii', 'Idaho', 'Illinois', 'Indiana', 'Iowa', 'Kansas', 'Maine',
  'Maryland', 'Michigan', 'Missouri', 'Mississippi', 'Montana', 'Nebraska',
  'New Hampshire', 'New Jersey', 'New York', 'North Dakota', 'Ohio',
  'Oklahoma', 'Oregon', 'Pennsylvania', 'South Dakota', 'Tennessee',
  'Texas', 'Washington', 'West Virginia', 'Wisconsin', 'Wyoming',
];
---

<Layout title="Sales Resource" active="sales-resource">
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <!-- Page Header -->
    <div class="mb-12">
      <p class="font-inter text-teal text-sm font-semibold uppercase tracking-[0.12em] mb-3">Nimbus Design</p>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Sales Resource
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[520px]">
        Reference materials and licensing information for the Nimbus sales team.
      </p>
    </div>

    <!-- Licensed States -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em]">Licensed States</p>
        <span class="font-inter text-xs font-semibold text-teal bg-teal/10 px-2.5 py-1 rounded-full">{states.length} States</span>
      </div>

      <div class="rounded-2xl border border-dark/8 overflow-hidden">
        <div class="bg-dark/3 px-6 py-4 border-b border-dark/8">
          <p class="font-inter text-sm text-dark/60">
            Nimbus is currently licensed to sell in the following states. Always verify current licensing status before engaging with prospective patients in a new state.
          </p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-0">
          {states.map((state, i) => (
            <div class={`px-5 py-3 font-inter text-sm text-dark font-medium border-dark/6 ${
              i % 4 !== 3 ? 'border-r' : ''
            } ${
              i < states.length - (states.length % 4 || 4) ? 'border-b' : ''
            }`}>
              {state}
            </div>
          ))}
        </div>
      </div>
    </section>

  </div>
</Layout>
