---
import Layout from '../layouts/Layout.astro';

const states = [
  'Alabama', 'Arizona', 'Arkansas', 'Colorado', 'Florida', 'Georgia',
  'Hawaii', 'Idaho', 'Illinois', 'Indiana', 'Iowa', 'Kansas', 'Maine',
  'Maryland', 'Michigan', 'Missouri', 'Mississippi', 'Montana', 'Nebraska',
  'New Hampshire', 'New Jersey', 'New York', 'North Dakota', 'Ohio',
  'Oklahoma', 'Oregon', 'Pennsylvania', 'South Dakota', 'Tennessee',
  'Texas', 'Washington', 'West Virginia', 'Wisconsin', 'Wyoming',
];

const coreSalesAssets = [
  {
    title: 'One-Pagers & Sell Sheets',
    description: 'Quick product and service overviews with key benefits, pricing tiers, and clear CTAs for prospects.',
  },
  {
    title: 'Pitch Deck Templates',
    description: 'Branded slide decks for discovery calls, demos, and proposals — ready to customize per audience.',
  },
  {
    title: 'Email Templates',
    description: 'Outreach sequences, follow-ups, and nurture campaigns with approved messaging and tone.',
  },
  {
    title: 'Proposal Templates',
    description: 'Standardized layouts for quotes, statements of work, and contracts to accelerate deal close.',
  },
];

const messagingAssets = [
  {
    title: 'Value Propositions',
    description: 'How to articulate Nimbus benefits for different customer segments, buyer personas, and use cases.',
  },
  {
    title: 'Competitive Differentiation',
    description: 'Key talking points and positioning vs. competitors — what makes Nimbus the clear choice.',
  },
  {
    title: 'Objection Handling Guide',
    description: 'Approved responses to common concerns, hesitations, and pushback encountered during the sales cycle.',
  },
  {
    title: 'Use Cases & Case Studies',
    description: 'Real customer stories with measurable outcomes to build trust and demonstrate proven results.',
  },
];

const visualAssets = [
  {
    title: 'Product Screenshots & Visuals',
    description: 'High-quality images of the portal, intake flow, and app with proper context and annotations.',
  },
  {
    title: 'Comparison Charts',
    description: 'Feature and pricing comparison tables to clearly communicate Nimbus advantages at a glance.',
  },
];
---

<Layout title="Sales Resources" active="sales-resource">
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <!-- Page Header -->
    <div class="mb-16">
      <p class="font-inter text-teal text-sm font-semibold uppercase tracking-[0.12em] mb-3">Nimbus Design</p>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Sales Resources
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[520px]">
        Assets, messaging, and reference materials for the Nimbus sales team.
      </p>
    </div>

    <!-- Core Sales Assets -->
    <section class="mb-16">
      <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em] mb-6">Core Sales Assets</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {coreSalesAssets.map((item) => (
          <div class="bg-warm-gray rounded-2xl p-6">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-fraunces text-dark text-lg leading-snug">{item.title}</h3>
              <span class="flex-shrink-0 mt-0.5 text-xs font-inter font-semibold text-dark/25 bg-dark/8 px-2.5 py-1 rounded-full">Coming soon</span>
            </div>
            <p class="font-inter text-dark/50 text-sm leading-[1.6]">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Messaging & Positioning -->
    <section class="mb-16">
      <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em] mb-6">Messaging & Positioning</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {messagingAssets.map((item) => (
          <div class="bg-warm-gray rounded-2xl p-6">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-fraunces text-dark text-lg leading-snug">{item.title}</h3>
              <span class="flex-shrink-0 mt-0.5 text-xs font-inter font-semibold text-dark/25 bg-dark/8 px-2.5 py-1 rounded-full">Coming soon</span>
            </div>
            <p class="font-inter text-dark/50 text-sm leading-[1.6]">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Visual Sales Tools -->
    <section class="mb-16">
      <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em] mb-6">Visual Sales Tools</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {visualAssets.map((item) => (
          <div class="bg-warm-gray rounded-2xl p-6">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-fraunces text-dark text-lg leading-snug">{item.title}</h3>
              <span class="flex-shrink-0 mt-0.5 text-xs font-inter font-semibold text-dark/25 bg-dark/8 px-2.5 py-1 rounded-full">Coming soon</span>
            </div>
            <p class="font-inter text-dark/50 text-sm leading-[1.6]">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Licensed States -->
    <section class="mb-16">
      <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em] mb-6">Licensed States</p>
      <ul style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem 1.5rem;">
        {states.map((state) => (
          <li class="font-inter text-sm text-dark">{state}</li>
        ))}
      </ul>
    </section>

  </div>
</Layout>
