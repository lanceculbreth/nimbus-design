---
import Layout from '../layouts/Layout.astro';

const states = [
  'Alabama', 'Arizona', 'Arkansas', 'Colorado', 'Florida', 'Georgia',
  'Hawaii', 'Idaho', 'Illinois', 'Indiana', 'Iowa', 'Kansas', 'Maine',
  'Maryland', 'Michigan', 'Missouri', 'Mississippi', 'Montana', 'Nebraska',
  'New Hampshire', 'New Jersey', 'New York', 'North Dakota', 'Ohio',
  'Oklahoma', 'Oregon', 'Pennsylvania', 'South Dakota', 'Tennessee',
  'Texas', 'Washington', 'West Virginia', 'Wisconsin', 'Wyoming',
];

const coreSalesAssets = [
  {
    title: 'One-Pagers & Sell Sheets',
    description: 'Quick product and service overviews with key benefits, pricing tiers, and clear CTAs for prospects.',
  },
  {
    title: 'Pitch Deck Templates',
    description: 'Branded slide decks for discovery calls, demos, and proposals — ready to customize per audience.',
  },
  {
    title: 'Email Templates',
    description: 'Outreach sequences, follow-ups, and nurture campaigns with approved messaging and tone.',
  },
  {
    title: 'Proposal Templates',
    description: 'Standardized layouts for quotes, statements of work, and contracts to accelerate deal close.',
  },
];

const messagingAssets = [
  {
    title: 'Value Propositions',
    description: 'How to articulate Nimbus benefits for different customer segments, buyer personas, and use cases.',
  },
  {
    title: 'Competitive Differentiation',
    description: 'Key talking points and positioning vs. competitors — what makes Nimbus the clear choice.',
  },
  {
    title: 'Objection Handling Guide',
    description: 'Approved responses to common concerns, hesitations, and pushback encountered during the sales cycle.',
  },
  {
    title: 'Use Cases & Case Studies',
    description: 'Real customer stories with measurable outcomes to build trust and demonstrate proven results.',
  },
];

const visualAssets = [
  {
    title: 'Product Screenshots & Visuals',
    description: 'High-quality images of the portal, intake flow, and app with proper context and annotations.',
  },
  {
    title: 'Comparison Charts',
    description: 'Feature and pricing comparison tables to clearly communicate Nimbus advantages at a glance.',
  },
];
---

<Layout title="Sales Resources" active="sales-resource" sections={[
  { label: 'Core Assets', id: 'core-assets' },
  { label: 'Messaging', id: 'messaging' },
  { label: 'Visual Tools', id: 'visual-tools' },
  { label: 'Licensed States', id: 'states' },
]}>
  <div class="max-w-[900px] mx-auto px-10 py-16">

    <!-- Page Header -->
    <div class="mb-16">
      <p class="font-inter text-teal text-sm font-semibold uppercase tracking-[0.12em] mb-3">Nimbus Design</p>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Sales Resources
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[520px]">
        Assets, messaging, and reference materials for the Nimbus sales team.
      </p>
    </div>

    <!-- Core Sales Assets -->
    <section id="core-assets" class="mb-16">
      <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em] mb-6">Core Sales Assets</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {coreSalesAssets.map((item) => (
          <div class="bg-warm-gray rounded-2xl p-6">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-fraunces text-dark text-lg leading-snug">{item.title}</h3>
              <span class="flex-shrink-0 mt-0.5 text-xs font-inter font-semibold text-dark/25 bg-dark/8 px-2.5 py-1 rounded-full">Coming soon</span>
            </div>
            <p class="font-inter text-dark/50 text-sm leading-[1.6]">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Messaging & Positioning -->
    <section id="messaging" class="mb-16">
      <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em] mb-6">Messaging & Positioning</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <!-- Value Propositions -->
        <div class="bg-warm-gray rounded-2xl p-6">
          <h3 class="font-fraunces text-dark text-lg leading-snug mb-4">Value Propositions</h3>
          <div class="space-y-4">
            <div>
              <p class="font-inter text-xs font-semibold text-teal uppercase tracking-[0.1em] mb-1">DTC — Nimbus Healthcare</p>
              <p class="font-inter text-sm text-dark/60 leading-[1.6]">Physician-led weight and hormone care that helps people feel aligned in body and mind — not a new you, but more like yourself. Medications delivered direct, with AI coaching in between.</p>
            </div>
            <div class="h-px bg-dark/8"></div>
            <div>
              <p class="font-inter text-xs font-semibold text-teal uppercase tracking-[0.1em] mb-1">B2B — Nimbus Providers</p>
              <p class="font-inter text-sm text-dark/60 leading-[1.6]">Metabolic health solutions clinicians can prescribe with confidence — backed by IntelliHealth™ clinical intelligence and a 503A NABP-accredited partner pharmacy.</p>
            </div>
            <div class="h-px bg-dark/8"></div>
            <div>
              <p class="font-inter text-xs font-semibold text-teal uppercase tracking-[0.1em] mb-1">B2B2C — Nimbus Teams</p>
              <p class="font-inter text-sm text-dark/60 leading-[1.6]">Flat-rate, clinician-guided metabolic health programs for employers who want a benefit employees actually use.</p>
            </div>
          </div>
        </div>

        <!-- Competitive Differentiation -->
        <div class="bg-warm-gray rounded-2xl p-6">
          <h3 class="font-fraunces text-dark text-lg leading-snug mb-4">Competitive Differentiation</h3>
          <ul class="space-y-3">
            {[
              { label: 'Medically supervised', body: 'Every treatment plan is physician-led — not a vanity prescription or algorithm-only decision.' },
              { label: 'Proprietary compounds', body: 'CarniSema® (semaglutide) and CarniTide® (tirzepatide) — more affordable and flexible than branded alternatives.' },
              { label: 'Tech-enabled, human-centered', body: 'IntelliHealth™ personalizes treatment decisions. Aura™ AI coach supports patients between clinical touchpoints.' },
              { label: 'One integrated platform', body: 'Clinical, pharmacy, and fulfillment infrastructure that works across all three channels seamlessly.' },
            ].map(item => (
              <li class="flex gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-teal flex-shrink-0 mt-[6px]"></span>
                <span class="font-inter text-sm text-dark/60 leading-[1.6]"><span class="font-semibold text-dark">{item.label}</span> — {item.body}</span>
              </li>
            ))}
          </ul>
          <div class="mt-5 pt-5 border-t border-dark/8">
            <p class="font-inter text-sm text-dark/70 leading-[1.6]"><span class="font-semibold">In short:</span> Clinical rigor, proprietary technology, and accessibility — in one platform, across three channels.</p>
          </div>
        </div>

        <!-- Objection Handling -->
        <div class="bg-warm-gray rounded-2xl p-6">
          <h3 class="font-fraunces text-dark text-lg leading-snug mb-4">Objection Handling</h3>
          <div class="space-y-4">
            {[
              { q: "Isn't this just Ozempic?", a: "We provide medically supervised metabolic health care — not aesthetic prescriptions. Every plan is physician-led and clinically appropriate." },
              { q: "Is this a quick fix?", a: "We don't sell 30-day challenges or transformation promises. Nimbus helps people feel steady and aligned — that's a process, not an event." },
              { q: "How is this different from competitors?", a: "One integrated platform: physician care, proprietary compounds, AI coaching, and direct pharmacy fulfillment — no stitched-together vendors." },
              { q: "Is this just weight loss?", a: "No. Hormone optimization and combination therapy address metabolic health holistically. WeightWise is one door of three." },
            ].map(item => (
              <div>
                <p class="font-inter text-sm font-semibold text-dark mb-1">{item.q}</p>
                <p class="font-inter text-sm text-dark/60 leading-[1.6]">{item.a}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Use Cases & Case Studies -->
        <div class="bg-warm-gray rounded-2xl p-6">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="font-fraunces text-dark text-lg leading-snug">Use Cases & Case Studies</h3>
            <span class="flex-shrink-0 mt-0.5 text-xs font-inter font-semibold text-dark/25 bg-dark/8 px-2.5 py-1 rounded-full">Coming soon</span>
          </div>
          <p class="font-inter text-dark/50 text-sm leading-[1.6]">Real customer stories with measurable outcomes to build trust and demonstrate proven results across DTC, provider, and employer channels.</p>
        </div>

      </div>
    </section>

    <!-- Visual Sales Tools -->
    <section id="visual-tools" class="mb-16">
      <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em] mb-6">Visual Sales Tools</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {visualAssets.map((item) => (
          <div class="bg-warm-gray rounded-2xl p-6">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-fraunces text-dark text-lg leading-snug">{item.title}</h3>
              <span class="flex-shrink-0 mt-0.5 text-xs font-inter font-semibold text-dark/25 bg-dark/8 px-2.5 py-1 rounded-full">Coming soon</span>
            </div>
            <p class="font-inter text-dark/50 text-sm leading-[1.6]">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Licensed States -->
    <section id="states" class="mb-16">
      <p class="font-inter text-xs font-semibold text-dark/30 uppercase tracking-[0.12em] mb-6">Licensed States</p>
      <ul style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem 1.5rem;">
        {states.map((state) => (
          <li class="font-inter text-sm text-dark">{state}</li>
        ))}
      </ul>
    </section>

  </div>
</Layout>
