---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Assets" active="assets">
  <div class="max-w-[900px] mx-auto px-10 py-16">
    <!-- Page Header -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-[2px] bg-teal"></div>
        <span class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase">Brand Assets</span>
        <div class="w-10 h-[2px] bg-teal"></div>
      </div>
      <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-5">
        Assets
      </h1>
      <p class="font-inter text-dark/50 text-lg leading-[1.6] max-w-[600px]">
        Logos, photography direction, and media guidelines for all Nimbus touchpoints.
      </p>
    </div>

    <!-- Logos -->
    <section id="logos" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Logo</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-dark rounded-3xl p-12 flex items-center justify-center min-h-[200px]">
          <span class="font-fraunces text-cream text-3xl tracking-[-0.02em]">Nimbus</span>
        </div>
        <div class="bg-cream border border-dark/10 rounded-3xl p-12 flex items-center justify-center min-h-[200px]">
          <span class="font-fraunces text-dark text-3xl tracking-[-0.02em]">Nimbus</span>
        </div>
      </div>

      <div class="bg-warm-gray rounded-3xl p-8">
        <h3 class="font-inter text-sm font-semibold mb-4">Logo Usage Rules</h3>
        <ul class="space-y-2 font-inter text-sm text-dark/60">
          <li>White logo on dark backgrounds (#1A1816 or darker)</li>
          <li>Black logo on light backgrounds (Cream, Warm Gray, White)</li>
          <li>Minimum clear space: 1x the height of the logo mark on all sides</li>
          <li>Never place the logo on busy or low-contrast backgrounds</li>
          <li>Never stretch, rotate, or alter the logo proportions</li>
        </ul>
      </div>
    </section>

    <!-- Photography -->
    <section id="photography" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Photography Direction</h2>

      <div class="bg-warm-gray rounded-3xl p-8 mb-8">
        <h3 class="font-inter text-sm font-semibold mb-2">Overall Tone</h3>
        <p class="font-inter text-dark/60 text-sm leading-[1.6]">
          Professional but human. Modern healthcare meets wellness lifestyle. Warm lighting, not clinical.
        </p>
      </div>

      <h3 class="font-inter text-dark/40 text-xs font-semibold tracking-[0.15em] uppercase mb-4">Subject Matter by Context</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        <div class="border border-dark/10 rounded-2xl p-6">
          <p class="font-inter text-sm font-semibold mb-1">Hero / Brand</p>
          <p class="font-inter text-dark/50 text-sm">Confident individuals in natural settings, warm light. Aspirational but authentic.</p>
        </div>
        <div class="border border-dark/10 rounded-2xl p-6">
          <p class="font-inter text-sm font-semibold mb-1">Clinical / Care</p>
          <p class="font-inter text-dark/50 text-sm">Provider-patient interactions, telehealth screens, personalized attention.</p>
        </div>
        <div class="border border-dark/10 rounded-2xl p-6">
          <p class="font-inter text-sm font-semibold mb-1">Nutrition / Food</p>
          <p class="font-inter text-dark/50 text-sm">Overhead flat-lay meal prep, fresh whole ingredients, vibrant and appetizing.</p>
        </div>
        <div class="border border-dark/10 rounded-2xl p-6">
          <p class="font-inter text-sm font-semibold mb-1">Product / Platform</p>
          <p class="font-inter text-dark/50 text-sm">Device mockups in lifestyle settings. Dashboards shown on screens in real environments.</p>
        </div>
        <div class="border border-dark/10 rounded-2xl p-6">
          <p class="font-inter text-sm font-semibold mb-1">Workplace / Teams</p>
          <p class="font-inter text-dark/50 text-sm">Modern offices, diverse professionals, HR and benefits context, natural light.</p>
        </div>
        <div class="border border-dark/10 rounded-2xl p-6">
          <p class="font-inter text-sm font-semibold mb-1">Outcomes / Results</p>
          <p class="font-inter text-dark/50 text-sm">Active lifestyle moments, people feeling good. Not posed gym shots.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-teal/10 rounded-3xl p-8">
          <h3 class="font-inter text-sm font-semibold text-teal mb-4">Do</h3>
          <ul class="space-y-2 font-inter text-sm text-dark/60">
            <li>Use natural light and warm tones</li>
            <li>Show real, diverse people</li>
            <li>Include environmental context (home, office, kitchen)</li>
            <li>Capture candid or natural-feeling moments</li>
          </ul>
        </div>
        <div class="bg-terracotta/10 rounded-3xl p-8">
          <h3 class="font-inter text-sm font-semibold text-terracotta mb-4">Don't</h3>
          <ul class="space-y-2 font-inter text-sm text-dark/60">
            <li>Use cold or clinical hospital imagery</li>
            <li>Use generic stock photo poses</li>
            <li>Over-saturate or use heavy filters</li>
            <li>Show isolated body parts or before/after comparisons</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Color in Photography -->
    <section id="photo-color" class="mb-20">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Color in Photography</h2>
      <div class="bg-warm-gray rounded-3xl p-8">
        <ul class="space-y-2 font-inter text-sm text-dark/60">
          <li>Warm natural lighting preferred</li>
          <li>Earth tones that complement the cream and terracotta palette</li>
          <li>Avoid harsh whites, cool blues, or sterile medical aesthetics</li>
        </ul>
      </div>
    </section>

    <!-- Video Direction -->
    <section id="video">
      <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">Video</h2>
      <div class="space-y-6">
        <div class="bg-warm-gray rounded-3xl p-8">
          <h3 class="font-inter text-sm font-semibold mb-4">Hero Background Videos</h3>
          <div class="space-y-2 font-inter text-sm text-dark/60">
            <p>Full viewport height with <span class="text-dark font-medium">50% dark overlay</span></p>
            <p>Autoplay, muted, looping</p>
            <p>Lifestyle content — natural movement, warm tones</p>
            <p>Never clinical or sterile environments</p>
          </div>
        </div>
        <div class="bg-warm-gray rounded-3xl p-8">
          <h3 class="font-inter text-sm font-semibold mb-4">Product Demo Videos</h3>
          <div class="space-y-2 font-inter text-sm text-dark/60">
            <p>Custom play/pause controls (no default browser UI)</p>
            <p>Rounded corners matching container radius (24px)</p>
            <p>Poster frame should be visually compelling</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
