---
import '../styles/global.css'

interface Props {
  title: string;
  active: string;
  sections?: Array<{ label: string; id: string }>;
}

const { title, active, sections = [] } = Astro.props;

const navItems = [
  { label: 'Overview', href: '/', id: 'overview' },
  { label: 'Assets', href: '/assets', id: 'assets' },
  { label: 'Positioning', href: '/marketing', id: 'marketing' },
  { label: 'Intakes', href: '/intakes', id: 'intakes' },
  { label: 'Web', href: '/web', id: 'web' },
  { label: 'Portal', href: '/portal', id: 'portal' },
  { label: 'Customer Touchpoints', href: '/email', id: 'email' },
  { label: 'Sales Resources', href: '/sales-resource', id: 'sales-resource' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Nimbus Healthcare Design System" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Inter:wght@400;500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title} — Nimbus Design</title>
  </head>
  <body class="bg-cream text-dark font-inter antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="fixed top-0 left-0 h-screen w-[240px] bg-dark flex flex-col z-50">
        <!-- Logo area -->
        <div class="px-7 pt-8 pb-10">
          <a href="/" class="block">
            <img src="/logos/logo-white.png" alt="Nimbus" class="h-[30px]" />
          </a>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-4">
          <ul class="space-y-1">
            {navItems.map(item => (
              <li>
                <a
                  href={item.href}
                  class={`block px-3 py-2.5 rounded-xl text-sm font-medium transition-colors ${
                    active === item.id
                      ? 'bg-cream/10 text-cream'
                      : 'text-cream/40 hover:text-cream/70 hover:bg-cream/5'
                  }`}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Footer -->
        <div class="px-4 py-5 border-t border-cream/10">
          <a href="https://nimbus-26.vercel.app" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between w-full px-3 py-2.5 text-cream/50 text-sm font-medium hover:text-cream transition-colors">
            <span>View Live Site</span>
            <span class="text-cream/40">&rarr;</span>
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="ml-[240px] flex-1 min-h-screen flex">
        <div class="flex-1 min-w-0">
          <slot />
        </div>

        <!-- Secondary Section Nav (or spacer to keep centering consistent) -->
        {sections.length > 0 ? (
          <aside class="hidden xl:block w-[160px] flex-shrink-0 py-16 pr-6">
            <nav class="sticky top-16" id="section-nav">
              <ul class="space-y-1">
                {sections.map((s, i) => (
                  <li>
                    <a
                      href={`#${s.id}`}
                      data-section={s.id}
                      class={`section-nav-link block text-xs py-1.5 px-2 rounded-lg transition-all duration-200 text-dark/30 hover:text-dark/70`}
                    >
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        ) : (
          <div class="hidden xl:block w-[160px] flex-shrink-0"></div>
        )}
      </main>
    </div>

    {sections.length > 0 && (
      <script is:inline>
        (function () {
          const links = document.querySelectorAll('.section-nav-link');
          if (!links.length) return;

          const ids = Array.from(links).map(l => l.dataset.section);

          function setActive(id) {
            links.forEach(l => {
              const isActive = l.dataset.section === id;
              l.classList.toggle('text-dark', isActive);
              l.classList.toggle('font-medium', isActive);
              l.classList.toggle('text-dark/30', !isActive);
            });
          }

          // Intersection Observer — track which section is in view
          const observer = new IntersectionObserver(
            entries => {
              entries.forEach(entry => {
                if (entry.isIntersecting) {
                  setActive(entry.target.id);
                }
              });
            },
            { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
          );

          ids.forEach(id => {
            const el = document.getElementById(id);
            if (el) observer.observe(el);
          });

          // Smooth scroll on click
          links.forEach(link => {
            link.addEventListener('click', e => {
              e.preventDefault();
              const id = link.dataset.section;
              const el = document.getElementById(id);
              if (el) {
                el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                setActive(id);
              }
            });
          });

          // Set first active on load
          if (ids[0]) setActive(ids[0]);
        })();
      </script>
    )}
  </body>
</html>
